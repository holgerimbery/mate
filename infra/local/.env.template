# mate — Local Environment Template
# ─────────────────────────────────────────────────────────────────────────────
# Copy this file to .env and fill in your values:
#   cp infra/local/.env.template infra/local/.env
#
# .env is gitignored and MUST NOT be committed to source control.
# Usage:
#   cd infra/local && docker compose up -d
# ─────────────────────────────────────────────────────────────────────────────

# ── Authentication ─────────────────────────────────────────────────────────
# "None"    — anonymous, no login required (default for local dev)
# "EntraId" — Microsoft Entra ID (Azure AD) OIDC
Authentication__Scheme=None

# ── Entra ID (Azure AD) ────────────────────────────────────────────────────
# Required only when Authentication__Scheme=EntraId
# How to obtain these values:
#   1. Azure Portal → Entra ID → App registrations → New registration
#   2. Redirect URI (type: Web):  https://<your-public-host>/signin-oidc
#   3. Front-channel logout URL:  https://<your-public-host>/signout-callback-oidc
#   4. Certificates & secrets → New client secret  → copy the Value (not the ID)
#   5. API permissions → Microsoft Graph → openid, profile, email (delegated)
#   6. App roles → create Admin / Tester / Viewer roles and assign users/groups
AzureAd__TenantId=YOUR_ENTRA_TENANT_ID
AzureAd__ClientId=YOUR_ENTRA_CLIENT_ID
AzureAd__ClientSecret=YOUR_ENTRA_CLIENT_SECRET
AzureAd__Instance=https://login.microsoftonline.com/

# Callback paths — must match Redirect URIs registered above (defaults are correct)
AzureAd__CallbackPath=/signin-oidc
AzureAd__SignedOutCallbackPath=/signout-callback-oidc

# Fully-qualified public URL nginx exposes — used to build the OIDC redirect_uri.
# Must be HTTPS. Example: https://mate.example.com
AzureAd__RedirectUri=https://YOUR_PUBLIC_HOST

# ── Reverse Proxy ──────────────────────────────────────────────────────────
# IP of the nginx proxy if it is outside the Docker bridge (172.16.0.0/12).
# Leave blank to trust the Docker bridge range automatically.
ReverseProxy__TrustedProxyAddress=

# ── AI Judge ───────────────────────────────────────────────────────────────
# Used by ModelAsJudge, HybridJudge, and CopilotStudioJudge modules.
# Compatible with Azure OpenAI and any OpenAI-compatible endpoint.
JUDGE_ENDPOINT=https://YOUR_OPENAI_ENDPOINT/openai/deployments/gpt-4o-mini/chat/completions?api-version=2024-02-01
JUDGE_API_KEY=YOUR_AI_API_KEY
JUDGE_MODEL=gpt-4o-mini

# ── Question Generation ────────────────────────────────────────────────────
# Used by the ModelQGen module to generate test cases from documents.
QUESTION_GEN_ENDPOINT=https://YOUR_OPENAI_ENDPOINT/openai/deployments/gpt-4o-mini/chat/completions?api-version=2024-02-01
QUESTION_GEN_API_KEY=YOUR_AI_API_KEY
QUESTION_GEN_MODEL=gpt-4o-mini

# ── Azure AI Foundry Agent Connector ───────────────────────────────────────
# Required only when using the AIFoundry agent connector module.
AIFOUNDRY_ENDPOINT=https://YOUR_AI_PROJECT.services.ai.azure.com
AIFOUNDRY_API_KEY=YOUR_AI_FOUNDRY_KEY
AIFOUNDRY_API_VERSION=2025-01-01

# ── Monitoring ─────────────────────────────────────────────────────────────
# "Generic"              — structured console/file logging only (default)
# "ApplicationInsights"  — Azure Application Insights
# "OpenTelemetry"        — OTLP exporter
Monitoring__Provider=Generic

# Application Insights (when Provider=ApplicationInsights)
# APPLICATIONINSIGHTS_CONNECTION_STRING=InstrumentationKey=YOUR_KEY;IngestionEndpoint=...

# OpenTelemetry OTLP exporter (when Provider=OpenTelemetry)
# OpenTelemetry__Endpoint=http://localhost:4317

# ── Infrastructure Provider ────────────────────────────────────────────────
# Controls the blob storage target at runtime:
#   "Container" — PostgreSQL + Azurite (default, Docker Desktop / CI)
#   "Azure"     — Azure Database for PostgreSQL + Azure Blob Storage (production)
# PostgreSQL is always used; this only selects the blob backend.
Infrastructure__Provider=Container

# ── Azure / Container Infrastructure ──────────────────────────────────────
# Container mode (Azurite): the well-known devstore connection string is set in docker-compose.yml.
# Azure mode: replace with your real Azure Blob Storage connection string.
# For Container mode the shorthand form is sufficient (SDK uses built-in Azurite dev credentials):
# AzureInfrastructure__BlobConnectionString=UseDevelopmentStorage=true;DevelopmentStorageProxyUri=http://azurite
# AzureInfrastructure__BlobContainerName=mate-blobs
