    private async Task CloneCase(TestSuite suite, TestCase source)
    {
        var clone = new TestCase
        {
            Id = Guid.NewGuid(),
            SuiteId = suite.Id,
            TenantId = suite.TenantId,
            Name = GetClonedCaseName(suite, source.Name),
            Description = source.Description,
            UserInput = source.UserInput.ToArray(),
            AcceptanceCriteria = source.AcceptanceCriteria,
            ExpectedIntent = source.ExpectedIntent,
            ExpectedEntities = source.ExpectedEntities.ToArray(),
            ReferenceAnswer = source.ReferenceAnswer,
            IsActive = source.IsActive,
            SortOrder = suite.TestCases.Count == 0 ? 1 : suite.TestCases.Max(tc => tc.SortOrder) + 1,
            Tags = source.Tags.ToArray(),
            SourceDocumentId = source.SourceDocumentId,
            CreatedAt = DateTime.UtcNow,
            UpdatedAt = DateTime.UtcNow
        };

        Db.TestCases.Add(clone);
        AuditHelper.Log(Db, suite.TenantId, "Cloned", "TestCase", clone.Id, _userId, $"{clone.Name} copied from {source.Name}");
        await Db.SaveChangesAsync();
        await LoadAsync();
    }

    private static string GetClonedCaseName(TestSuite suite, string sourceName)
    {
        var existingNames = suite.TestCases
            .Select(tc => tc.Name)
            .ToHashSet(StringComparer.OrdinalIgnoreCase);

        var copyName = $"{sourceName} (Copy)";
        if (!existingNames.Contains(copyName))
        {
            return copyName;
        }

        var suffix = 2;
        while (existingNames.Contains($"{sourceName} (Copy {suffix})"))
        {
            suffix++;
        }

        return $"{sourceName} (Copy {suffix})";
    }

    private async Task SaveCase()
    {
        if (string.IsNullOrWhiteSpace(_caseForm.Name)) { _caseFormError = "Name is required."; return; }
        var inputs = _caseForm.UserInputRaw
            .Split('\n', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries);
        if (inputs.Length == 0) { _caseFormError = "At least one user input is required."; return; }

        var entities = _caseForm.ExpectedEntitiesRaw
            .Split(',', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries);
        var caseTags = _caseForm.TagsRaw
            .Split(',', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries);

        if (_editCase is null)
        {
            var tc = new TestCase
            {
                Id = Guid.NewGuid(),
                SuiteId = _caseParentSuite!.Id,
                TenantId = _caseParentSuite!.TenantId,
                Name = _caseForm.Name,
                Description = _caseForm.Description,
                UserInput = inputs,
                AcceptanceCriteria = _caseForm.AcceptanceCriteria,
                ExpectedIntent = _caseForm.ExpectedIntent,
                ExpectedEntities = entities,
                ReferenceAnswer = _caseForm.ReferenceAnswer,
                Tags = caseTags,
                SortOrder = _caseForm.SortOrder,
                CreatedAt = DateTime.UtcNow,
                UpdatedAt = DateTime.UtcNow
            };
            Db.TestCases.Add(tc);
            AuditHelper.Log(Db, TenantCtx.TenantId, "Created", "TestCase", tc.Id, _userId, tc.Name);
        }
        else
        {
            _editCase.Name = _caseForm.Name;
            _editCase.Description = _caseForm.Description;
            _editCase.UserInput = inputs;
            _editCase.AcceptanceCriteria = _caseForm.AcceptanceCriteria;
            _editCase.ExpectedIntent = _caseForm.ExpectedIntent;
            _editCase.ExpectedEntities = entities;
            _editCase.ReferenceAnswer = _caseForm.ReferenceAnswer;
            _editCase.Tags = caseTags;
            _editCase.SortOrder = _caseForm.SortOrder;
            _editCase.IsActive = _caseForm.IsActive;
            _editCase.UpdatedAt = DateTime.UtcNow;
            AuditHelper.Log(Db, _editCase.TenantId, "Updated", "TestCase", _editCase.Id, _userId, _editCase.Name);
        }
        await Db.SaveChangesAsync();
        CloseCaseForm();
        await LoadAsync();
    }

