    private async Task SaveSuite()
    {
        if (string.IsNullOrWhiteSpace(_suiteForm.Name)) { _suiteFormError = "Name is required."; return; }
        if (_suiteForm.PassThreshold is < 0 or > 1) { _suiteFormError = "Pass threshold must be 0–1."; return; }

        var tags = _suiteForm.TagsRaw
            .Split(',', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries);
        var judgeId = Guid.TryParse(_suiteForm.JudgeSettingId, out var jg) ? (Guid?)jg : null;

        if (_editSuite is null)
        {
            var suite = new TestSuite
            {
                Id = Guid.NewGuid(),
                TenantId = TenantCtx.TenantId,
                Name = _suiteForm.Name,
                Description = _suiteForm.Description,
                Tags = tags,
                PassThreshold = _suiteForm.PassThreshold,
                IsActive = _suiteForm.IsActive,
                JudgeSettingId = judgeId,
                DelayBetweenTestsMs = Math.Max(0, _suiteForm.DelayBetweenTestsMs),
                CreatedAt = DateTime.UtcNow,
                UpdatedAt = DateTime.UtcNow
            };
            Db.TestSuites.Add(suite);
            AuditHelper.Log(Db, TenantCtx.TenantId, "Created", "TestSuite", suite.Id, _userId, suite.Name);
        }
        else
        {
            _editSuite.Name = _suiteForm.Name;
            _editSuite.Description = _suiteForm.Description;
            _editSuite.Tags = tags;
            _editSuite.PassThreshold = _suiteForm.PassThreshold;
            _editSuite.IsActive = _suiteForm.IsActive;
            _editSuite.JudgeSettingId = judgeId;
            _editSuite.DelayBetweenTestsMs = Math.Max(0, _suiteForm.DelayBetweenTestsMs);
            _editSuite.UpdatedAt = DateTime.UtcNow;
            AuditHelper.Log(Db, _editSuite.TenantId, "Updated", "TestSuite", _editSuite.Id, _userId, _editSuite.Name);
        }
        await Db.SaveChangesAsync();
        CloseSuiteForm();
        await LoadAsync();
    }

    private void CloseSuiteForm()
    {
        _showSuiteForm = false;
        _genMessage = string.Empty;
        _qgenSourceContent = string.Empty;
        _selectedDocumentId = string.Empty;
