        _qgenUseManualText = false;
    }

    private async Task LoadDocumentContent()
    {
        if (!Guid.TryParse(_selectedDocumentId, out var docId)) return;
        _loadingDocContent = true;
        StateHasChanged();
        try
        {
            var doc = await Db.Documents
                .Include(d => d.Chunks)
                .FirstOrDefaultAsync(d => d.Id == docId);
            if (doc is null) { _genMessage = "Document not found."; return; }
            _qgenSourceContent = string.Join("\n\n", doc.Chunks.OrderBy(c => c.ChunkIndex).Select(c => c.Text));
            _loadedDocName = doc.FileName;
        }
        finally
        {
            _loadingDocContent = false;
        }
    }

    private static string FormatDocSize(long bytes)
    {
        if (bytes < 1024L) return $"{bytes} B";
        if (bytes < 1024L * 1024L) return $"{bytes / 1024.0:F1} KB";
        return $"{bytes / (1024.0 * 1024.0):F1} MB";
    }

