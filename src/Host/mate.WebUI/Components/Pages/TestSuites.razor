@attribute [Authorize]
@page "/test-suites"
@using mate.Data
@using mate.Domain.Contracts.Infrastructure
@using mate.Domain.Contracts.Modules
@using mate.Domain.Entities
@using Microsoft.EntityFrameworkCore
@using Microsoft.AspNetCore.Components.Authorization
@inject mateDbContext Db
@inject IMessageQueue Queue
@inject NavigationManager Nav
@inject AuthenticationStateProvider AuthStateProvider
@inject mate.Core.mateModuleRegistry Registry
@inject ISecretService SecretSvc
@inject ITenantContext TenantCtx

<PageTitle>Test Suites — @BrandInfo.BrandName</PageTitle>

@if (!_showSuiteForm && _runSuite is null)
{
    <PageHeader Title="Test Suites" Description="Manage test suites, test cases, and run evaluations against your agents." />
    <div class="mate-page">
        <div class="section-card">
            <div class="section-header">
                <span class="section-title">All Test Suites</span>
                <button class="btn btn-primary btn-sm" @onclick="OpenCreateSuite">
                    <i class="bi bi-plus-lg"></i> New Suite
                </button>
            </div>
            @if (_loading)
            {
                <p><em>Loading…</em></p>
            }
            else
            {
                <table class="data-table">
                    <thead>
                        <tr>
                            <th>Name</th>
                            <th>Cases</th>
                            <th>Pass Threshold</th>
                            <th>Active</th>
                            <th></th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var suite in _suites)
                        {
                            <tr>
                                <td>
                                    <strong>@suite.Name</strong><br />
                                    <small>@suite.Description</small>
                                    @if (suite.Tags.Length > 0)
                                    {
                                        <div class="d-flex flex-wrap gap-1 mt-1">
                                            @foreach (var t in suite.Tags)
                                            {
                                                <span style="font-size:11px;background:var(--light-bg);border:1px solid var(--border);border-radius:4px;padding:1px 6px">@t</span>
                                            }
                                        </div>
                                    }
                                </td>
                                <td>@suite.TestCases.Count</td>
                                <td>@suite.PassThreshold.ToString("P0")</td>
                                <td>@(suite.IsActive ? "✓" : "✗")</td>
                                <td>
                                    <button class="btn btn-sm btn-secondary" @onclick="() => ExpandSuite(suite)">
                                        @(_expandedSuiteId == suite.Id ? "▲ Hide Cases" : "▼ Show Cases")
                                    </button>
                                    <button class="btn btn-sm btn-primary" @onclick="() => OpenRun(suite)"><i class="bi bi-play-fill"></i> Run</button>
                                    <button class="btn btn-sm btn-secondary" @onclick="() => OpenEditSuite(suite)">Edit</button>
                                    <button class="btn btn-sm btn-danger" @onclick="() => ConfirmDeleteSuite(suite)">Delete</button>
                                </td>
                            </tr>
                            @if (_expandedSuiteId == suite.Id)
                            {
                                <tr>
                                    <td colspan="5" style="padding:0 1rem 1rem;background:var(--surface-2);color:var(--text-primary)">
                                        <div class="section-header" style="margin-top:12px;margin-bottom:8px">
                                            <strong>Test Cases</strong>
                                            <button class="btn btn-sm btn-primary" @onclick="() => OpenAddCase(suite)">
                                                <i class="bi bi-plus-lg"></i> Add Case
                                            </button>
                                        </div>
                                        <table class="data-table sub-table">
                                            <thead>
                                                <tr>
                                                    <th>#</th>
                                                    <th>Name</th>
                                                    <th>Input(s)</th>
                                                    <th>Active</th>
                                                    <th></th>
                                                </tr>
                                            </thead>
                                            <tbody>
                                                @foreach (var tc in suite.TestCases.OrderBy(t => t.SortOrder))
                                                {
                                                    <tr>
                                                        <td>@tc.SortOrder</td>
                                                        <td>
                                                            @tc.Name<br /><small>@tc.Description</small>
                                                            @if (tc.Tags.Length > 0)
                                                            {
                                                                <div class="d-flex flex-wrap gap-1 mt-1">
                                                                    @foreach (var t in tc.Tags)
                                                                    {
                                                                        <span style="font-size:11px;background:var(--light-bg);border:1px solid var(--border);border-radius:4px;padding:1px 6px">@t</span>
                                                                    }
                                                                </div>
                                                            }
                                                        </td>
                                                        <td><small>@string.Join(" → ", tc.UserInput.Take(2))@(tc.UserInput.Length > 2 ? "…" : "")</small></td>
                                                        <td>@(tc.IsActive ? "✓" : "✗")</td>
                                                        <td>
                                                            <button class="btn btn-sm btn-secondary" @onclick="() => CloneCase(suite, tc)">Clone</button>
                                                            <button class="btn btn-sm btn-secondary" @onclick="() => OpenEditCase(tc)">Edit</button>
                                                            <button class="btn btn-sm btn-danger" @onclick="() => ConfirmDeleteCase(tc)">Delete</button>
                                                        </td>
                                                    </tr>
                                                }
                                                @if (!suite.TestCases.Any())
                                                {
                                                    <tr><td colspan="5" class="empty-row">No test cases yet.</td></tr>
                                                }
                                            </tbody>
                                        </table>
                                    </td>
                                </tr>
                            }
                        }
                        @if (!_suites.Any())
                        {
                            <tr><td colspan="5" class="empty-row">No test suites yet.</td></tr>
                        }
                    </tbody>
                </table>
            }
        </div>
    </div>
}
else if (_showSuiteForm)
{
    <PageHeader
        Title="@(_editSuite is null ? "New Test Suite" : "Edit Test Suite — " + _editSuite.Name)"
        Description="@(_editSuite is null ? "Create a new test suite to organise test cases." : "Update test suite details.")" />
    <div class="mate-page">
        <div class="section-card">
            <h2 class="section-title mb-4">Suite Details</h2>
            <div class="form-group">
                <label class="form-label">Name *</label>
                <input class="form-control" @bind="_suiteForm.Name" placeholder="Suite name" />
            </div>
            <div class="form-group">
                <label class="form-label">Description</label>
                <input class="form-control" @bind="_suiteForm.Description" placeholder="Optional description" />
            </div>
            <div class="form-group">
                <label class="form-label">Tags <small class="text-muted">(comma-separated)</small></label>
                <input class="form-control" @bind="_suiteForm.TagsRaw" placeholder="regression, smoke, api" />
            </div>
            <div class="form-group">
                <label class="form-label">Pass Threshold (0–1)</label>
                <input class="form-control" type="number" min="0" max="1" step="0.05" @bind="_suiteForm.PassThreshold" style="width:140px" />
                <small class="text-muted">Score 0–1 required to pass (e.g. 0.7 = 70%)</small>
            </div>
            <div class="form-group">
                <label class="form-label">Delay Between Tests <small class="text-muted">(milliseconds)</small></label>
                <input class="form-control" type="number" min="0" max="60000" step="500" @bind="_suiteForm.DelayBetweenTestsMs" style="width:160px" />
                <small class="text-muted">Pause between each test case execution. Increase if the agent returns rate-limit errors (e.g. 2000 = 2 s). 0 = no delay.</small>
            </div>
            @if (_editSuite is not null)
            {
                <div class="form-group">
                    <label class="form-label">
                        <input type="checkbox" @bind="_suiteForm.IsActive" class="me-2" />
                        Active
                    </label>
                </div>
            }
            @if (!string.IsNullOrWhiteSpace(_suiteFormError))
            {
                <div class="alert alert-danger"><i class="bi bi-exclamation-circle"></i> @_suiteFormError</div>
            }
        </div>

        <div class="section-card">
            <h2 class="section-title mb-3" style="color:var(--secondary)"><i class="bi bi-award me-2"></i>Judge Configuration</h2>
            @{
                var defaultJudge = _judgeSettings.FirstOrDefault(j => j.IsDefault);
            }
            @if (defaultJudge is not null)
            {
                <div style="background:rgba(139,92,246,0.08);padding:10px 14px;border-radius:6px;border-left:4px solid var(--secondary);font-size:13px;margin-bottom:16px">
                    <strong>System default:</strong> @defaultJudge.Name (@defaultJudge.ProviderType) — threshold @defaultJudge.PassThreshold.ToString("P0")
                </div>
            }
            <div class="form-group">
                <label class="form-label">Judge Setting Override</label>
                <select class="form-control" @bind="_suiteForm.JudgeSettingId">
                    <option value="">— Use system default —</option>
                    @foreach (var js in _judgeSettings)
                    {
                        <option value="@js.Id">@js.Name (@js.ProviderType)@(js.IsDefault ? " [default]" : "")</option>
                    }
                </select>
                <small class="text-muted">Leave blank to inherit the system default judge setting.</small>
            </div>
            @{
                var selJudge = _judgeSettings.FirstOrDefault(j => j.Id.ToString() == _suiteForm.JudgeSettingId);
            }
            @if (selJudge is not null)
            {
                <div style="background:var(--surface-2);padding:12px;border-radius:8px;border-left:4px solid var(--secondary);font-size:13px;margin-top:8px">
                    <div class="mb-1"><strong>Provider:</strong> @selJudge.ProviderType</div>
                    <div class="mb-1"><strong>Pass Threshold:</strong> @selJudge.PassThreshold.ToString("P0")</div>
                    <div class="mb-1"><strong>Weights:</strong> Task @selJudge.TaskSuccessWeight.ToString("P0") · Intent @selJudge.IntentMatchWeight.ToString("P0") · Factuality @selJudge.FactualityWeight.ToString("P0") · Helpfulness @selJudge.HelpfulnessWeight.ToString("P0") · Safety @selJudge.SafetyWeight.ToString("P0")</div>
                    @if (!string.IsNullOrWhiteSpace(selJudge.Model))
                    {
                        <div><strong>Model:</strong> @selJudge.Model</div>
                    }
                    @if (!string.IsNullOrWhiteSpace(selJudge.PromptTemplate))
                    {
                        <div class="mt-1"><strong>Custom prompt:</strong> <span class="text-muted">configured</span></div>
                    }
                </div>
            }
            @if (!_judgeSettings.Any())
            {
                <p class="text-muted" style="font-size:13px;margin-top:8px">No judge settings configured yet. Add them in <a href="/settings">Settings → AI Judge</a>.</p>
            }
        </div>

        <div class="section-card">
            <h2 class="section-title mb-3" style="color:var(--success)"><i class="bi bi-stars me-2"></i>AI Question Generation</h2>
            @if (_qgenSetting is not null)
            {
                <div style="background:rgba(32,201,151,0.08);padding:10px 14px;border-radius:6px;border-left:4px solid var(--success);font-size:13px;margin-bottom:16px">
                    <strong>System default:</strong> @_qgenSetting.Model
                    @if (!string.IsNullOrWhiteSpace(_qgenSetting.SystemPrompt))
                    {
                        <span class="ms-2 text-muted">(custom prompt configured)</span>
                    }
                    else
                    {
                        <span class="ms-2 text-muted">(using built-in prompt)</span>
                    }
                </div>
            }
            else
            {
                <div class="alert alert-info mb-3" style="font-size:13px"><i class="bi bi-info-circle me-1"></i> No global question generation settings found. Configure them in <a href="/settings">Settings → Question Generation</a>.</div>
            }
            <div class="form-group" style="max-width:160px">
                <label class="form-label">Question Count</label>
                <input class="form-control" type="number" min="1" max="50" @bind="_suiteForm.QuestionGenCount" />
            </div>
            <div class="form-group">
                <div class="d-flex align-items-center gap-2 mb-1">
                    <label class="form-label mb-0">System Prompt Override <small class="text-muted">(leave blank to use system default)</small></label>
                    @if (string.IsNullOrWhiteSpace(_suiteForm.QuestionGenPrompt))
                    {
                        <button class="btn btn-sm btn-outline-secondary" type="button" @onclick="LoadDefaultQGenPrompt">
                            <i class="bi bi-clipboard-plus me-1"></i>Load default to edit
                        </button>
                    }
                    else
                    {
                        <button class="btn btn-sm btn-outline-warning" type="button" @onclick="ClearQGenPrompt">
                            <i class="bi bi-x-circle me-1"></i>Revert to system default
                        </button>
                    }
                </div>
                <textarea class="form-control" rows="8" @bind="_suiteForm.QuestionGenPrompt"
                    style="font-family:monospace;font-size:.85em"
                    placeholder="Leave blank to use the system default prompt from Settings"></textarea>
            </div>
            @if (_editSuite is not null)
            {
                <div class="form-group">
                    <label class="form-label">Source Content</label>
                    @if (!_qgenUseManualText)
                    {
                        <div class="d-flex align-items-center gap-2 mb-2">
                            <select class="form-control" style="flex:1" @bind="_selectedDocumentId">
                                <option value="">— select an uploaded document —</option>
                                @foreach (var doc in _documents)
                                {
                                    <option value="@doc.Id">@doc.FileName (@FormatDocSize(doc.FileSizeBytes), @doc.ChunkCount chunk@(doc.ChunkCount == 1 ? "" : "s"))</option>
                                }
                            </select>
                            <button class="btn btn-sm btn-outline-secondary" type="button"
                                    @onclick="LoadDocumentContent"
                                    disabled="@(string.IsNullOrWhiteSpace(_selectedDocumentId)|| _loadingDocContent)">
                                @if (_loadingDocContent) { <span class="spinner me-1"></span> }
                                Load Content
                            </button>
                        </div>
                        @if (_documents.Count == 0)
                        {
                            <small class="text-muted"><i class="bi bi-info-circle me-1"></i>No documents uploaded yet. <a href="/documents">Upload one first.</a></small>
                        }
                        else if (!string.IsNullOrWhiteSpace(_qgenSourceContent))
                        {
                            <div class="alert alert-success py-2" style="font-size:12px">
                                <i class="bi bi-check-circle me-1"></i>Loaded <strong>@_loadedDocName</strong> — @_qgenSourceContent.Length.ToString("N0") characters ready.
                            </div>
                        }
                        <div class="mt-1">
                            <button class="btn btn-link btn-sm p-0" style="font-size:12px" type="button" @onclick="() => _qgenUseManualText = true">
                                <i class="bi bi-pencil me-1"></i>Paste text manually instead
                            </button>
                        </div>
                    }
                    else
                    {
                        <textarea class="form-control" rows="6" @bind="_qgenSourceContent"
                            style="font-size:.85em"
                            placeholder="Paste the document or knowledge base content here."></textarea>
                        <div class="mt-1">
                            <button class="btn btn-link btn-sm p-0" style="font-size:12px" type="button" @onclick="() => { _qgenUseManualText = false; _qgenSourceContent = string.Empty; }">
                                <i class="bi bi-file-earmark-text me-1"></i>Select from uploaded documents instead
                            </button>
                        </div>
                    }
                </div>
            }
            @if (!string.IsNullOrWhiteSpace(_genMessage))
            {
                <div class="alert @(_genMessage.StartsWith("Error") ? "alert-danger" : (_genMessage.StartsWith("✓") ? "alert-success" : "alert-info")) mb-3">@_genMessage</div>
            }
            @if (_editSuite is null)
            {
                <p class="text-muted" style="font-size:13px"><i class="bi bi-info-circle me-1"></i>Save the suite first, then return to edit it and generate questions.</p>
            }
            else
            {
                <div class="d-flex gap-2">
                    <button class="btn btn-secondary" disabled="@_generatingQuestions" @onclick="GenerateQuestionsAdd">
                        @if (_generatingQuestions) { <span class="spinner me-2"></span> }
                        <i class="bi bi-plus-lg me-1"></i> Add @_suiteForm.QuestionGenCount Questions
                    </button>
                    <button class="btn btn-secondary" disabled="@_generatingQuestions" @onclick="GenerateQuestionsReplace">
                        <i class="bi bi-arrow-clockwise me-1"></i> Replace All
                    </button>
                </div>
            }
        </div>

        <div class="d-flex gap-2 mb-4">
            <button class="btn btn-primary" @onclick="SaveSuite">
                <i class="bi bi-check-lg"></i> @(_editSuite is null ? "Create Suite" : "Save Changes")
            </button>
            <button class="btn btn-secondary" @onclick="CloseSuiteForm">
                <i class="bi bi-x-lg"></i> Cancel
            </button>
        </div>
    </div>
}

@* ── Test case form modal ──────────────────────────────────────────────────── *@
@if (_showCaseForm)
{
    <div class="modal-backdrop" @onclick="CloseCaseForm">
        <div class="modal-box wide-modal" @onclick:stopPropagation>
            <h2 class="modal-title mb-4">@(_editCase is null ? "Add Test Case" : "Edit Test Case")</h2>
            <div class="form-group">
                <label class="form-label">Name *</label>
                <input class="form-control" @bind="_caseForm.Name" placeholder="Case name" />
            </div>
            <div class="form-group">
                <label class="form-label">Description</label>
                <input class="form-control" @bind="_caseForm.Description" placeholder="Optional description" />
            </div>
            <div class="form-group">
                <label class="form-label">User Input <small class="text-muted">(one message per line; multi-turn = multiple lines)</small></label>
                <textarea class="form-control" rows="4" @bind="_caseForm.UserInputRaw" placeholder="What can you help me with?"></textarea>
            </div>
            <div class="form-group">
                <label class="form-label">Acceptance Criteria</label>
                <textarea class="form-control" rows="3" @bind="_caseForm.AcceptanceCriteria" placeholder="The bot should…"></textarea>
            </div>
            <div class="form-group">
                <label class="form-label">Expected Intent</label>
                <input class="form-control" @bind="_caseForm.ExpectedIntent" placeholder="Optional" />
            </div>
            <div class="form-group">
                <label class="form-label">Expected Entities <small class="text-muted">(comma-separated)</small></label>
                <input class="form-control" @bind="_caseForm.ExpectedEntitiesRaw" placeholder="city, date" />
            </div>
            <div class="form-group">
                <label class="form-label">Reference Answer</label>
                <textarea class="form-control" rows="3" @bind="_caseForm.ReferenceAnswer" placeholder="Optional golden answer"></textarea>
            </div>
            <div class="form-group">
                <label class="form-label">Tags <small class="text-muted">(comma-separated)</small></label>
                <input class="form-control" @bind="_caseForm.TagsRaw" placeholder="billing, happy-path, auth" />
            </div>
            <div class="form-group">
                <label class="form-label">Sort Order</label>
                <input class="form-control" type="number" @bind="_caseForm.SortOrder" style="width:100px" />
            </div>
            @if (!string.IsNullOrWhiteSpace(_caseFormError))
            {
                <div class="alert alert-danger"><i class="bi bi-exclamation-circle"></i> @_caseFormError</div>
            }
            <div class="modal-actions">
                <button class="btn btn-primary" @onclick="SaveCase">
                    <i class="bi bi-check-lg"></i> @(_editCase is null ? "Add Case" : "Save Changes")
                </button>
                <button class="btn btn-secondary" @onclick="CloseCaseForm">Cancel</button>
            </div>
        </div>
    </div>
}

@* ── Run view (in-page, no modal) ────────────────────────────────────────── *@
@if (_runSuite is not null && !_showSuiteForm)
{
    <PageHeader
        Title="@($"Run — {_runSuite.Name}")"
        Description="Configure and start a test run for this suite." />
    <div class="mate-page">
        <div class="section-card">
            <h2 class="section-title mb-4">Suite Details</h2>
            <div class="row g-3">
                <div class="col-md-4">
                    <div class="form-group">
                        <label class="form-label">Suite</label>
                        <div class="fw-600">@_runSuite.Name</div>
                        @if (!string.IsNullOrWhiteSpace(_runSuite.Description))
                        {
                            <small class="text-muted">@_runSuite.Description</small>
                        }
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="form-group">
                        <label class="form-label">Active Test Cases</label>
                        <div class="fw-600">@_runSuite.TestCases.Count(tc => tc.IsActive)</div>
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="form-group">
                        <label class="form-label">Pass Threshold</label>
                        <div class="fw-600">@((_runSuite.PassThreshold * 100).ToString("0"))%</div>
                    </div>
                </div>
            </div>
        </div>

        <div class="section-card">
            <h2 class="section-title mb-4">Run Configuration</h2>
            <div class="row g-3">
                <div class="col-md-8">
                    <div class="form-group">
                        <label class="form-label">Agent *</label>
                        <select class="form-control" @bind="_selectedAgentId">
                            <option value="">— choose agent —</option>
                            @foreach (var agent in _agents)
                            {
                                <option value="@agent.Id">@agent.Name (@agent.Environment)</option>
                            }
                        </select>
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="form-group">
                        <label class="form-label">Judge</label>
                        <div class="text-muted" style="font-size:13px;padding-top:6px">
                            @if (_runSuite.JudgeSettingId.HasValue)
                            {
                                var j = _judgeSettings.FirstOrDefault(x => x.Id == _runSuite.JudgeSettingId);
                                @(j?.Name ?? "Suite default")
                            }
                            else
                            {
                                <span>Tenant default</span>
                            }
                        </div>
                    </div>
                </div>
            </div>

            @if (_runInProgress)
            {
                <div class="d-flex align-items-center gap-3 mt-3">
                    <span class="spinner"></span>
                    <span>@_runStatus</span>
                </div>
            }

            @if (!string.IsNullOrWhiteSpace(_runError))
            {
                <div class="alert alert-danger mt-3"><i class="bi bi-exclamation-circle"></i> @_runError</div>
            }

            <div class="d-flex gap-2 mt-4">
                <button class="btn btn-primary" @onclick="StartRun"
                        disabled="@(string.IsNullOrEmpty(_selectedAgentId) || _runInProgress)">
                    <i class="bi bi-play-fill"></i> Start Run
                </button>
                <button class="btn btn-secondary" @onclick="CloseRunModal" disabled="@_runInProgress">Cancel</button>
            </div>
        </div>
    </div>
}

@* ── Delete confirmations ──────────────────────────────────────────────────── *@
@if (_deleteSuite is not null)
{
    <div class="modal-backdrop" @onclick="() => _deleteSuite = null">
        <div class="modal-box" @onclick:stopPropagation>
            <h2>Delete Suite</h2>
            <p>Delete <strong>@_deleteSuite.Name</strong> and all its test cases?</p>
            <div class="modal-actions">
                <button class="btn btn-danger" @onclick="DeleteSuite">Delete</button>
                <button class="btn btn-secondary" @onclick="() => _deleteSuite = null">Cancel</button>
            </div>
        </div>
    </div>
}

@if (_deleteCase is not null)
{
    <div class="modal-backdrop" @onclick="() => _deleteCase = null">
        <div class="modal-box" @onclick:stopPropagation>
            <h2>Delete Test Case</h2>
            <p>Delete <strong>@_deleteCase.Name</strong>?</p>
            <div class="modal-actions">
                <button class="btn btn-danger" @onclick="DeleteCase">Delete</button>
                <button class="btn btn-secondary" @onclick="() => _deleteCase = null">Cancel</button>
            </div>
        </div>
    </div>
}

@code {
    private bool _loading = true;
    private string _userId = string.Empty;
    private List<TestSuite> _suites = [];
    private List<Agent> _agents = [];
    private List<JudgeSetting> _judgeSettings = [];
    private GlobalQuestionGenerationSetting? _qgenSetting;
    private Guid? _expandedSuiteId;

    // Suite form
    private bool _showSuiteForm;
    private TestSuite? _editSuite;
    private TestSuite? _deleteSuite;
    private string _suiteFormError = string.Empty;
    private SuiteFormModel _suiteForm = new();

    // Documents list
    private List<Document> _documents = [];

    // Question generation
    private bool _generatingQuestions;
    private string _genMessage = string.Empty;
    private string _qgenSourceContent = string.Empty;
    private string _selectedDocumentId = string.Empty;
    private bool _qgenUseManualText;
    private bool _loadingDocContent;
    private string _loadedDocName = string.Empty;

    // Case form
    private bool _showCaseForm;
    private TestCase? _editCase;
    private TestCase? _deleteCase;
    private TestSuite? _caseParentSuite;
    private string _caseFormError = string.Empty;
    private CaseFormModel _caseForm = new();

    // Run
    private TestSuite? _runSuite;
    private string _selectedAgentId = string.Empty;
    private bool _runInProgress;
    private string _runStatus = string.Empty;
    private string _runError = string.Empty;

    private class SuiteFormModel
    {
        public string Name { get; set; } = string.Empty;
        public string Description { get; set; } = string.Empty;
        public string TagsRaw { get; set; } = string.Empty;
