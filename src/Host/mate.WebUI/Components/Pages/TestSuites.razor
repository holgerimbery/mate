    private async Task GenerateQuestionsAdd()     => await GenerateQuestionsImpl(replace: false);
    private async Task GenerateQuestionsReplace() => await GenerateQuestionsImpl(replace: true);

    private async Task GenerateQuestionsImpl(bool replace)
    {
        if (_editSuite is null)
        {
            _genMessage = "Save the suite first before generating questions.";
            return;
        }

        var providers = Registry.GetAllQuestionProviders();
        if (providers.Count == 0)
        {
            _genMessage = "No question generation provider registered. Make sure the ModelQGen module is loaded.";
            return;
        }

        if (_qgenSetting is null)
        {
            _genMessage = "Configure question generation settings first (Settings → Question Generation).";
            return;
        }

        if (string.IsNullOrWhiteSpace(_qgenSetting.Endpoint))
        {
            _genMessage = "The question generation endpoint is not configured (Settings → Question Generation).";
            return;
        }

        if (string.IsNullOrWhiteSpace(_qgenSourceContent))
        {
            _genMessage = "Select and load a document (or paste text manually) into the Source Content field first.";
            return;
        }

        _generatingQuestions = true;
        _genMessage = string.Empty;
        StateHasChanged();

        try
        {
            // Resolve API key secret — fall back to treating the ref as a raw value
            // (supports legacy configs where the raw key was stored directly in ApiKeyRef)
            string apiKey;
            if (string.IsNullOrWhiteSpace(_qgenSetting.ApiKeyRef))
            {
                apiKey = string.Empty;
            }
            else
            {
                try { apiKey = await SecretSvc.GetSecretAsync(_qgenSetting.ApiKeyRef) ?? string.Empty; }
                catch { apiKey = _qgenSetting.ApiKeyRef; }
            }

            // Collect existing questions to avoid duplicates
            var existingQuestions = _editSuite.TestCases
                .Select(tc => tc.UserInput.FirstOrDefault() ?? string.Empty)
                .Where(q => !string.IsNullOrWhiteSpace(q))
                .ToList();

            var request = new QuestionGenerationRequest
            {
                DocumentContent      = _qgenSourceContent,
                NumberOfQuestions    = _suiteForm.QuestionGenCount,
                SystemPromptOverride = string.IsNullOrWhiteSpace(_suiteForm.QuestionGenPrompt) ? null : _suiteForm.QuestionGenPrompt,
                ExistingQuestions    = existingQuestions,
                ResolvedEndpoint     = _qgenSetting.Endpoint,
                ResolvedApiKey       = apiKey,
                Model                = _qgenSetting.Model,
            };

            var generated = await providers[0].GenerateAsync(request);

            if (generated.Count == 0)
            {
                _genMessage = "The LLM returned no questions. Check the source content and endpoint settings.";
                return;
            }

            if (replace)
                Db.TestCases.RemoveRange(_editSuite.TestCases);

            var maxOrder = replace
                ? 0
                : (_editSuite.TestCases.Any() ? _editSuite.TestCases.Max(tc => tc.SortOrder) : 0);

            foreach (var q in generated)
            {
                Db.TestCases.Add(new TestCase
                {
                    Id                 = Guid.NewGuid(),
                    SuiteId            = _editSuite.Id,
                    TenantId           = TenantCtx.TenantId,
                    Name               = q.Question.Length > 80 ? q.Question[..77] + "…" : q.Question,
                    Description        = q.Rationale ?? string.Empty,
                    UserInput          = [q.Question],
                    AcceptanceCriteria = q.ExpectedAnswer,
                    ExpectedIntent     = q.ExpectedIntent,
                    ExpectedEntities   = q.ExpectedEntities,
                    ReferenceAnswer    = q.ExpectedAnswer,
                    SortOrder          = ++maxOrder,
                    IsActive           = true,
                    CreatedAt          = DateTime.UtcNow,
                    UpdatedAt          = DateTime.UtcNow,
                });
            }

            await Db.SaveChangesAsync();
            _genMessage = $"✓ {(replace ? "Replaced all with" : "Added")} {generated.Count} AI-generated test case{(generated.Count == 1 ? "" : "s")}.";
            _qgenSourceContent = string.Empty;
            await LoadAsync();
            _editSuite = _suites.FirstOrDefault(s => s.Id == _editSuite.Id);
        }
        catch (Exception ex)
        {
            _genMessage = $"Error: {ex.Message}";
        }
        finally
        {
            _generatingQuestions = false;
        }
    }

    private const string QGenBuiltInDefault =
        "You are a test case generator for AI assistants. Generate realistic, diverse user questions " +
        "that test the assistant's capabilities.\n\nFor each question:\n" +
        "- Make it natural and conversational\n" +
        "- Cover different aspects of the domain\n" +
        "- Include edge cases and varied complexity\n" +
        "- Avoid yes/no questions; prefer open-ended or task-based questions\n\n" +
        "Return the questions as a JSON array of strings: [\"Question 1\", \"Question 2\", ...]";

