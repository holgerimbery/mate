@* ── API Keys ─────────────────────────────────────────────────────────────── *@
@if (_tab == "apikeys")
{
    <div class="section-card">
        <div class="section-header mb-3">
            <span class="section-title">API Keys</span>
            <button class="btn btn-primary btn-sm" @onclick='() => _showCreateKey = true'>
                <i class="bi bi-plus-lg me-1"></i>Generate Key
            </button>
        </div>
        <p class="text-muted mb-4" style="font-size:13px">API keys grant machine-to-machine access for CI/CD pipelines and external tooling. The raw key is shown only once on creation — store it in a secure secret store.</p>

        @if (_newRawKey is not null)
        {
            <div class="alert alert-success mb-4">
                <div class="d-flex justify-content-between align-items-start">
                    <div>
                        <strong><i class="bi bi-key me-1"></i>New API key — copy now, it won't be shown again:</strong><br />
                        <code style="font-size:13px;word-break:break-all">@_newRawKey</code>
                    </div>
                    <button class="btn btn-sm btn-outline-success ms-3" @onclick="() => _newRawKey = null">Dismiss</button>
                </div>
            </div>
        }

        @if (_apiKeys.Any())
        {
            <table class="data-table">
                <thead>
                    <tr>
                        <th>Name</th>
                        <th>Prefix</th>
                        <th>Role</th>
                        <th>Status</th>
                        <th>Created</th>
                        <th>Last Used</th>
                        <th></th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var key in _apiKeys)
                    {
                        <tr>
                            <td><strong>@key.Name</strong></td>
                            <td><code style="font-size:12px">@key.Prefix…</code></td>
                            <td><span class="connector-badge">@key.Role</span></td>
                            <td>
                                @if (key.IsActive)
                                { <span class="badge badge-pass">Active</span> }
                                else
                                { <span class="badge badge-fail">Revoked</span> }
                            </td>
                            <td style="font-size:12px">@key.CreatedAt.ToString("yyyy-MM-dd")</td>
                            <td style="font-size:12px">@(key.LastUsedAt?.ToString("yyyy-MM-dd HH:mm") ?? "Never")</td>
                            <td>
                                @if (key.IsActive)
                                {
                                    <button class="btn btn-sm btn-danger" @onclick="() => RevokeKey(key)">Revoke</button>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        }
        else
        {
            <div class="empty-state">
                <i class="bi bi-key"></i>
                <h3>No API keys yet</h3>
                <p>Generate a key to enable CI/CD pipeline integration and external API access.</p>
            </div>
        }
    </div>
}

