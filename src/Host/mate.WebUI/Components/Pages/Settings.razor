    private async Task PingLlmAsync(string endpoint, string apiKey, string model)
    {
        var url = endpoint.TrimEnd('/');
        if (!url.Contains("/chat/completions", StringComparison.OrdinalIgnoreCase))
            url = $"{url}/openai/deployments/{model}/chat/completions?api-version=2024-02-01";

        var body = JsonSerializer.Serialize(new
        {
            model,
            messages = new[] { new { role = "user", content = "ping" } },
            max_tokens = 5
        });
        var http = HttpClientFactory.CreateClient("SettingsTest");
        var req = new HttpRequestMessage(HttpMethod.Post, url)
        {
            Content = new StringContent(body, System.Text.Encoding.UTF8, "application/json")
        };
        req.Headers.Add("api-key", apiKey);
        using var cts = new System.Threading.CancellationTokenSource(TimeSpan.FromSeconds(15));
        var resp = await http.SendAsync(req, cts.Token);
        if (!resp.IsSuccessStatusCode)
        {
            var err = await resp.Content.ReadAsStringAsync();
            throw new InvalidOperationException($"HTTP {(int)resp.StatusCode}: {err[..Math.Min(200, err.Length)]}");
        }
    }

    // ── API Keys ──────────────────────────────────────────────────────────────

    private async Task GenerateKey()
    {
        _keyError = string.Empty;
        if (string.IsNullOrWhiteSpace(_newKeyName)) { _keyError = "Name is required."; return; }
        var allowedKeyRoles = new HashSet<string>(StringComparer.Ordinal)
        {
            "SuperAdmin", "TenantAdmin", "Tester", "Viewer"
        };
        if (!allowedKeyRoles.Contains(_newKeyRole)) { _keyError = "Role must be one of: SuperAdmin, TenantAdmin, Tester, Viewer."; return; }
        var rawKey = $"mate_{Convert.ToBase64String(RandomNumberGenerator.GetBytes(32)).Replace("+", "-").Replace("/", "_").TrimEnd('=')}";
        var hash = Convert.ToHexString(SHA256.HashData(System.Text.Encoding.UTF8.GetBytes(rawKey))).ToLowerInvariant();
        var apiKey = new ApiKey
        {
            Id = Guid.NewGuid(),
            TenantId = TenantCtx.TenantId,
            Name = _newKeyName,
            Prefix = rawKey[..12],
            KeyHash = hash,
            Role = _newKeyRole,
            IsActive = true,
            CreatedAt = DateTime.UtcNow
        };
        Db.ApiKeys.Add(apiKey);
        AuditHelper.Log(Db, TenantCtx.TenantId, "Created", "ApiKey", apiKey.Id, _userId, $"{_newKeyName} (role: {_newKeyRole})");
        await Db.SaveChangesAsync();
        _newRawKey = rawKey;
        _showCreateKey = false;
        _newKeyName = string.Empty;
        await LoadAllAsync();
    }

