@attribute [Authorize]
@page "/settings"
@using mate.Data
@using mate.Domain.Entities
@using mate.Domain.Contracts.Modules
@using mate.Domain.Contracts.Monitoring
@using mate.Domain.Contracts.RedTeaming
@using Microsoft.EntityFrameworkCore
@using System.Security.Cryptography
@using System.Net.Http
@using System.Text.Json
@using AuditLogEntity = mate.Domain.Entities.AuditLog
@using Microsoft.Extensions.Configuration
@inject mateDbContext Db
@inject IJSRuntime JS
@inject ITenantContext TenantCtx
@inject mate.Core.mateModuleRegistry Registry
@inject mate.Domain.Contracts.Infrastructure.ISecretService SecretSvc
@inject IHttpClientFactory HttpClientFactory
@inject NavigationManager NavigationManager
@inject IConfiguration Config
@inject AuthenticationStateProvider AuthStateProvider

<PageTitle>Settings — @BrandInfo.BrandName</PageTitle>

<PageHeader Title="Settings" Description="Configure modules, judges, question generation, API keys, appearance, data, and authentication." />
<div class="mate-page">

<div class="tab-pills mb-4">
    <button class="tab-pill @(_tab == "modules" ? "active" : "")" @onclick='() => _tab = "modules"'><i class="bi bi-puzzle me-1"></i>Modules</button>
    <button class="tab-pill @(_tab == "judge" ? "active" : "")" @onclick='() => _tab = "judge"'><i class="bi bi-award me-1"></i>AI Judge</button>
    <button class="tab-pill @(_tab == "qgen" ? "active" : "")" @onclick='() => _tab = "qgen"'><i class="bi bi-question-circle me-1"></i>Question Generation</button>
    <button class="tab-pill @(_tab == "apikeys" ? "active" : "")" @onclick='() => _tab = "apikeys"'><i class="bi bi-key me-1"></i>API Keys</button>
    <button class="tab-pill @(_tab == "auditlog" ? "active" : "")" @onclick='() => _tab = "auditlog"'><i class="bi bi-journal-text me-1"></i>Audit Log</button>
    <button class="tab-pill @(_tab == "appearance" ? "active" : "")" @onclick='() => _tab = "appearance"'><i class="bi bi-moon-stars me-1"></i>Appearance</button>
    <button class="tab-pill @(_tab == "data" ? "active" : "")" @onclick='() => _tab = "data"'><i class="bi bi-database me-1"></i>Data Management</button>
    <button class="tab-pill @(_tab == "auth" ? "active" : "")" @onclick='() => _tab = "auth"'><i class="bi bi-shield-lock me-1"></i>Authentication</button>
</div>

@* ── Modules overview ──────────────────────────────────────────────────────── *@
@if (_tab == "modules")
{
    <div class="tab-content">
        <p class="text-muted mb-4">All module implementations registered at startup. Modules are plug-in libraries loaded via dependency injection and discoverable at runtime.</p>

        <h2 class="section-title">Agent Connector Modules</h2>
        <div class="row g-3 mb-4">
            @foreach (var m in _connectorModules)
            {
                <div class="col-md-6 col-lg-4">
                    <div class="section-card h-100">
                        <div class="d-flex align-items-center gap-3 mb-3">
                            <div class="icon-tile-md icon-tile-primary-soft">
                                <i class="bi @ConnectorIcon(m.ConnectorType)" style="color:var(--primary);font-size:18px"></i>
                            </div>
                            <div>
                                <div style="font-weight:600">@m.DisplayName</div>
                                <span class="connector-badge">@m.ConnectorType</span>
                            </div>
                            <span class="badge @(m.Tier == ModuleTier.Premium ? "badge-premium" : "badge-free") ms-auto">@m.Tier</span>
                            <span class="badge badge-pass">Active</span>
                        </div>
                        @{
                            var fields = m.GetConfigDefinition().ToList();
                        }
                        @if (fields.Any())
                        {
                            <div style="font-size:12px;color:var(--text-secondary);margin-bottom:8px">@fields.Count config field@(fields.Count == 1 ? "" : "s")</div>
                            <div class="d-flex flex-wrap gap-1">
                                @foreach (var f in fields)
                                {
                                    var fieldTitle = f.Description + (f.IsRequired ? " (required)" : string.Empty);
                                    <span style="font-size:11px;background:var(--light-bg);border:1px solid var(--border);border-radius:4px;padding:2px 6px" title="@fieldTitle">
                                        @f.Label@(f.IsRequired ? " *" : "")
                                    </span>
                                }
                            </div>
                        }
                        <div class="mt-3">
                            <a href="/wizard" class="btn btn-primary btn-sm"><i class="bi bi-plus-lg me-1"></i>Create Agent</a>
                        </div>
                    </div>
                </div>
            }
            @if (!_connectorModules.Any())
            {
                <div class="col-12">
                    <div class="empty-state"><i class="bi bi-plug"></i><p>No connector modules registered.</p></div>
                </div>
            }
        </div>

        <h2 class="section-title">Judge / Evaluation Modules</h2>
        <div class="row g-3 mb-4">
            @foreach (var m in _judgeModules)
            {
                <div class="col-md-6 col-lg-4">
                    <div class="section-card h-100">
                        <div class="d-flex align-items-center gap-3 mb-3">
                            <div class="icon-tile-md icon-tile-success-soft">
                                <i class="bi bi-award" style="color:var(--success);font-size:18px"></i>
                            </div>
                            <div>
                                <div style="font-weight:600">@m.DisplayName</div>
                                <span class="connector-badge">@m.ProviderType</span>
                            </div>
                            <span class="badge @(m.Tier == ModuleTier.Premium ? "badge-premium" : "badge-free") ms-auto">@m.Tier</span>
                            <span class="badge badge-pass">Active</span>
                        </div>
                        @{
                            var jFields = m.GetJudgeConfigDefinition().ToList();
                        }
                        @if (jFields.Any())
                        {
                            <div class="d-flex flex-wrap gap-1">
                                @foreach (var f in jFields)
                                {
                                    <span style="font-size:11px;background:var(--light-bg);border:1px solid var(--border);border-radius:4px;padding:2px 6px">@f.Label</span>
                                }
                            </div>
                        }
                        <div class="mt-3">
                            <button class="btn btn-secondary btn-sm" @onclick='() => { _tab = "judge"; }'><i class="bi bi-gear me-1"></i>Configure</button>
                        </div>
                    </div>
                </div>
            }
            @if (!_judgeModules.Any())
            {
                <div class="col-12">
                    <div class="empty-state"><i class="bi bi-award"></i><p>No judge modules registered.</p></div>
                </div>
            }
        </div>

        <h2 class="section-title">Monitoring Modules</h2>
        <div class="row g-3 mb-4">
            @foreach (var m in _monitoringModules)
            {
                <div class="col-md-6 col-lg-4">
                    <div class="section-card">
                        <div class="d-flex align-items-center gap-3">
                            <div class="icon-tile-md icon-tile-warning-soft">
                                <i class="bi bi-activity" style="color:var(--warning);font-size:18px"></i>
                            </div>
                            <div>
                                <div style="font-weight:600">@m.DisplayName</div>
                                <span class="connector-badge">@m.ProviderType</span>
                            </div>
                            <span class="badge @(m.Tier == ModuleTier.Premium ? "badge-premium" : "badge-free") ms-auto">@m.Tier</span>
                            <span class="badge badge-pass">Active</span>
                        </div>
                    </div>
                </div>
            }
            @if (!_monitoringModules.Any())
            {
                <div class="col-12">
                    <div class="empty-state"><i class="bi bi-activity"></i><p>No monitoring modules registered.</p></div>
                </div>
            }
        </div>

        <h2 class="section-title">Question Generation Modules</h2>
        <div class="row g-3 mb-4">
            @foreach (var m in _qgenModules)
            {
                <div class="col-md-6 col-lg-4">
                    <div class="section-card h-100">
                        <div class="d-flex align-items-center gap-3 mb-3">
                            <div class="icon-tile-md icon-tile-teal-soft">
                                <i class="bi bi-stars" style="color:var(--success);font-size:18px"></i>
                            </div>
                            <div>
                                <div style="font-weight:600">@QGenDisplayName(m.ProviderType)</div>
                                <span class="connector-badge">@m.ProviderType</span>
                            </div>
                            <span class="badge @(m.Tier == ModuleTier.Premium ? "badge-premium" : "badge-free") ms-auto">@m.Tier</span>
                            <span class="badge badge-pass">Active</span>
                        </div>
                        <div class="mt-3">
                            <button class="btn btn-secondary btn-sm" @onclick='() => { _tab = "qgen"; }'><i class="bi bi-gear me-1"></i>Configure</button>
                        </div>
                    </div>
                </div>
            }
            @if (!_qgenModules.Any())
            {
                <div class="col-12">
                    <div class="empty-state"><i class="bi bi-stars"></i><p>No question generation modules registered.</p></div>
                </div>
            }
        </div>

        <h2 class="section-title">Red Teaming Modules</h2>
        <div class="row g-3">
            @foreach (var m in _redTeamModules)
            {
                <div class="col-md-6 col-lg-4">
                    <div class="section-card h-100">
                        <div class="d-flex align-items-center gap-3 mb-3">
                            <div class="icon-tile-md icon-tile-danger-soft">
                                <i class="bi bi-shield-exclamation" style="color:var(--danger);font-size:18px"></i>
                            </div>
                            <div>
                                <div style="font-weight:600">@m.DisplayName</div>
                                <span class="connector-badge">@m.ProviderType</span>
                            </div>
                            <span class="badge @(m.Tier == ModuleTier.Premium ? "badge-premium" : "badge-free") ms-auto">@m.Tier</span>
                            <span class="badge badge-pass">Active</span>
                        </div>
                        @{
                            var caps = m.GetCapabilities();
                        }
                        @if (caps.Any())
                        {
                            <div style="font-size:12px;color:var(--text-secondary);margin-bottom:6px">Attack categories</div>
                            <div class="d-flex flex-wrap gap-1">
                                @foreach (var cap in caps)
                                {
                                    <span style="font-size:11px;background:var(--light-bg);border:1px solid var(--border);border-radius:4px;padding:2px 6px">@cap.Replace('_', ' ')</span>
                                }
                            </div>
                        }
                        @if (m.ConfigSchema.Any())
                        {
                            <div style="font-size:12px;color:var(--text-secondary);margin-top:8px">@m.ConfigSchema.Count config field@(m.ConfigSchema.Count == 1 ? "" : "s")</div>
                        }
                    </div>
                </div>
            }
            @if (!_redTeamModules.Any())
            {
                <div class="col-12">
                    <div class="empty-state"><i class="bi bi-shield-exclamation"></i><p>No red-teaming modules registered.</p></div>
                </div>
            }
        </div>
    </div>
}

@* ── AI Judge settings ───────────────────────────────────────────────────── *@
@if (_tab == "judge")
{
    @if (!_showJudgeForm)
    {
        <div class="section-card">
            <div class="section-header">
                <span class="section-title">AI Judge Configurations</span>
                <button class="btn btn-primary btn-sm" @onclick="OpenCreateJudge">
                    <i class="bi bi-plus-lg"></i> New Judge Setting
                </button>
            </div>
            @if (_judgeSettings.Any())
            {
                <table class="data-table">
                    <thead>
                        <tr>
                            <th>Name</th>
                            <th>Provider</th>
                            <th>Model</th>
                            <th>Pass Threshold</th>
                            <th>Rubric Sets</th>
                            <th></th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var js in _judgeSettings)
                        {
                            <tr>
                                <td>
                                    <strong>@js.Name</strong>
                                    @if (js.IsDefault)
                                    {
                                        <span class="badge badge-pass ms-2">default</span>
                                    }
                                </td>
                                <td>@js.ProviderType</td>
                                <td>@(js.Model ?? "global")</td>
                                <td>@js.PassThreshold.ToString("P0")</td>
                                <td style="font-size:12px">
                                    @{ var linked = _rubricSets.Where(r => r.JudgeSettingId == js.Id).ToList(); }
                                    @if (linked.Any())
                                    {
                                        @foreach (var rs in linked)
                                        {
                                            <span class="connector-badge me-1">@rs.Name</span>
                                        }
                                    }
                                    else
                                    {
                                        <span style="color:var(--text-secondary)">&#x2014;</span>
                                    }
                                </td>
                                <td>
                                    <button class="btn btn-sm btn-secondary" @onclick="() => OpenEditJudge(js)">Edit</button>
                                    <button class="btn btn-sm btn-danger" @onclick="() => ConfirmDeleteJudge(js)">Delete</button>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            }
            else
            {
                <p class="empty-row">No judge settings configured yet. Create one to enable AI evaluation.</p>
            }
        </div>
    }
    else
    {
        <div class="section-card">
            <h2 class="section-title mb-4">@(_editJudge is null ? "New Judge Setting" : "Edit — " + _judgeForm.Name)</h2>
            <div class="row g-3">
                <div class="col-md-6">
                    <div class="form-group">
                        <label class="form-label">Name *</label>
                        <input class="form-control" @bind="_judgeForm.Name" @bind:event="oninput" placeholder="Default Judge" />
                    </div>
                </div>
                <div class="col-md-6">
                    <div class="form-group">
                        <label class="form-label">Provider Type</label>
                        <select class="form-control" @bind="_judgeForm.ProviderType">
                            @foreach (var m in _judgeModules)
                            {
                                <option value="@m.ProviderType">@m.DisplayName</option>
                            }
                            @if (!_judgeModules.Any())
                            {
                                <option value="ModelAsJudge">ModelAsJudge</option>
                                <option value="Rubrics">Rubrics</option>
                                <option value="Hybrid">Hybrid</option>
                                <option value="CopilotStudioJudge">CopilotStudioJudge</option>
                            }
                        </select>
                    </div>
                </div>
            </div>
            <div class="row g-3">
                <div class="col-md-4">
                    <div class="form-group">
                        <label class="form-label">Model <small class="text-muted">(blank = global)</small></label>
                        <input class="form-control" @bind="_judgeForm.Model" @bind:event="oninput" placeholder="gpt-4o" />
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="form-group">
                        <label class="form-label">Endpoint</label>
                        <input class="form-control" @bind="_judgeForm.EndpointRef" @bind:event="oninput" placeholder="https://...openai.azure.com/" />
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="form-group">
                        <label class="form-label">
                            API Key
                            @if (!string.IsNullOrWhiteSpace(_judgeForm.ApiKeyRef)) {
                                <small class="text-muted ms-1">(configured — enter new to replace)</small>
                            }
                        </label>
                        <input type="password" class="form-control" @bind="_judgeForm.ApiKeyInput" @bind:event="oninput"
                               placeholder="@(string.IsNullOrWhiteSpace(_judgeForm.ApiKeyRef) ? "Enter API key" : "Enter new key to replace current")" autocomplete="new-password" />
                    </div>
                </div>
            </div>
            <div class="row g-3">
                <div class="col-md-3">
                    <div class="form-group">
                        <label class="form-label">Temperature</label>
                        <input class="form-control" type="number" step="0.05" min="0" max="2" @bind="_judgeForm.Temperature" />
                    </div>
                </div>
                <div class="col-md-3">
                    <div class="form-group">
                        <label class="form-label">Top P</label>
                        <input class="form-control" type="number" step="0.05" min="0" max="1" @bind="_judgeForm.TopP" />
                    </div>
                </div>
                <div class="col-md-3">
                    <div class="form-group">
                        <label class="form-label">Max Output Tokens</label>
                        <input class="form-control" type="number" @bind="_judgeForm.MaxOutputTokens" />
                    </div>
                </div>
                <div class="col-md-3">
                    <div class="form-group">
                        <label class="form-label">Pass Threshold (0–1)</label>
                        <input class="form-control" type="number" step="0.05" min="0" max="1" @bind="_judgeForm.PassThreshold" />
                    </div>
                </div>
            </div>

            <h3 class="section-title mt-3 mb-3" style="font-size:14px">Scoring Weights <small class="text-muted">(should sum to 1.0)</small></h3>
            <div class="row g-3">
                <div class="col">
                    <div class="form-group">
                        <label class="form-label">Task Success</label>
                        <input class="form-control" type="number" step="0.05" @bind="_judgeForm.TaskSuccessWeight" />
                    </div>
                </div>
                <div class="col">
                    <div class="form-group">
                        <label class="form-label">Intent Match</label>
                        <input class="form-control" type="number" step="0.05" @bind="_judgeForm.IntentMatchWeight" />
                    </div>
                </div>
                <div class="col">
                    <div class="form-group">
                        <label class="form-label">Factuality</label>
                        <input class="form-control" type="number" step="0.05" @bind="_judgeForm.FactualityWeight" />
                    </div>
                </div>
                <div class="col">
                    <div class="form-group">
                        <label class="form-label">Helpfulness</label>
                        <input class="form-control" type="number" step="0.05" @bind="_judgeForm.HelpfulnessWeight" />
                    </div>
                </div>
                <div class="col">
                    <div class="form-group">
                        <label class="form-label">Safety</label>
                        <input class="form-control" type="number" step="0.05" @bind="_judgeForm.SafetyWeight" />
                    </div>
                </div>
            </div>

            <div class="form-group mt-3">
                <div class="d-flex align-items-center gap-2 mb-1">
                    <label class="form-label mb-0">Custom Prompt Template <small class="text-muted">(optional — overrides built-in judge prompt)</small></label>
                    @if (string.IsNullOrWhiteSpace(_judgeForm.PromptTemplate))
                    {
                        <button class="btn btn-sm btn-outline-secondary" type="button" @onclick="LoadDefaultJudgePrompt">
                            <i class="bi bi-clipboard-plus me-1"></i>Load default to edit
                        </button>
                    }
                    else
                    {
                        <button class="btn btn-sm btn-outline-warning" type="button" @onclick="() => _judgeForm.PromptTemplate = null">
                            <i class="bi bi-x-circle me-1"></i>Revert to built-in
                        </button>
                    }
                </div>
                <textarea class="form-control" rows="12" @bind="_judgeForm.PromptTemplate" @bind:event="oninput"
                    style="font-family:monospace;font-size:.85em"
                    placeholder="Leave blank to use the built-in model-as-judge evaluation prompt"></textarea>
                <small class="text-muted">Leave blank = built-in prompt is used. Individual test suites can further override this.</small>
            </div>

            <div class="row g-3 mt-1">
                <div class="col-auto">
                    <div class="form-group">
                        <label class="form-label">
                            <input type="checkbox" @bind="_judgeForm.UseReferenceAnswer" class="me-2" />
                            Use Reference Answer
                        </label>
                    </div>
                </div>
                <div class="col-auto">
                    <div class="form-group">
                        <label class="form-label">
                            <input type="checkbox" @bind="_judgeForm.IsDefault" class="me-2" />
                            Set as Default Judge
                        </label>
                    </div>
                </div>
            </div>

            @if (!string.IsNullOrWhiteSpace(_judgeFormError))
            {
                <div class="alert alert-danger mt-2"><i class="bi bi-exclamation-circle me-1"></i>@_judgeFormError</div>
            }

            @if (_editJudge is not null)
            {
                var linkedSets = _rubricSets.Where(r => r.JudgeSettingId == _editJudge.Id).ToList();
                <div class="form-group mt-3" style="background:var(--light-bg);border-radius:8px;padding:14px;border-left:4px solid var(--primary)">
                    <div style="font-size:12px;font-weight:600;color:var(--primary);margin-bottom:8px;text-transform:uppercase;letter-spacing:0.5px">
                        <i class="bi bi-list-check me-1"></i>Linked Rubric Sets
                    </div>
                    @if (linkedSets.Any())
                    {
                        <ul style="margin:0;padding-left:18px;font-size:13px">
                            @foreach (var rs in linkedSets)
                            {
                                <li>@rs.Name <span style="color:var(--text-secondary);font-size:11px">(@rs.Criteria.Count criteria)</span></li>
                            }
                        </ul>
                    }
                    else
                    {
                        <span style="font-size:13px;color:var(--text-secondary)">No rubric sets linked to this judge yet.</span>
                    }
                    @if (_editJudge.ProviderType == "CopilotStudioJudge")
                    {
                        <div style="margin-top:10px;padding:10px 12px;background:rgba(var(--primary-rgb),0.06);border-radius:6px;border:1px solid rgba(var(--primary-rgb),0.15);font-size:12px">
                            <strong><i class="bi bi-info-circle me-1"></i>Built-in default rubrics (always applied)</strong>
                            <ul style="margin:6px 0 0;padding-left:18px">
                                <li><strong>Non-empty response</strong> — <span class="connector-badge">Custom:NonEmpty</span> <span class="badge badge-fail ms-1" style="font-size:10px">Mandatory</span> — empty bot response is an immediate fail regardless of score</li>
                                <li><strong>No blank rejection</strong> — <span class="connector-badge">NotContains</span> &ldquo;I'm not able to help with that&rdquo; (weight 0.5)</li>
                                <li><strong>No unhandled error</strong> — <span class="connector-badge">NotContains</span> &ldquo;Something went wrong&rdquo; (weight 0.5)</li>
                            </ul>
                            <div style="margin-top:6px;color:var(--text-secondary)">Custom rubric sets linked above are <strong>appended</strong> to these defaults — they are never replaced.</div>
                        </div>
                    }
                    <div style="font-size:12px;color:var(--text-secondary);margin-top:8px">
                        Manage rubric sets and link them to this judge on the <a href="/rubrics">Rubrics page</a>.
                    </div>
                </div>
            }
        </div>
        <div class="d-flex gap-2 mb-4">
            <button class="btn btn-primary" @onclick="SaveJudge">
                <i class="bi bi-check-lg"></i> @(_editJudge is null ? "Create Judge Setting" : "Save Changes")
            </button>
            <button class="btn btn-secondary" disabled="@_judgeTesting" @onclick="TestJudgeConnectionAsync">
                @if (_judgeTesting)
                {
                    <span class="spinner me-2"></span>
                }
                else if (_judgeTestPassed.HasValue)
                {
                    @if (_judgeTestPassed.Value)
                    {
                        <i class="bi bi-check-circle-fill text-success me-1"></i>
                    }
                    else
                    {
                        <i class="bi bi-exclamation-triangle-fill text-warning me-1"></i>
                    }
                }
                else
                {
                    <i class="bi bi-wifi me-1"></i>
                }
                Test Connection
            </button>
            <button class="btn btn-secondary" @onclick="CloseJudgeForm">
                <i class="bi bi-x-lg"></i> Cancel
            </button>
        </div>
        @if (!string.IsNullOrWhiteSpace(_judgeTestMessage))
        {
            <div class="alert @(_judgeTestPassed == true ? "alert-success" : "alert-warning") mb-4">
                <i class="bi @(_judgeTestPassed == true ? "bi-check-circle" : "bi-exclamation-triangle") me-1"></i>@_judgeTestMessage
            </div>
        }
    }
}

@* ── Question generation settings ────────────────────────────────────────── *@
@if (_tab == "qgen")
{
    @if (!_showQGenForm)
    {
        <div class="section-card">
            <div class="section-header mb-3">
                <span class="section-title">Question Generation Configurations</span>
                <button class="btn btn-primary btn-sm" @onclick="OpenCreateQGen">
                    <i class="bi bi-plus-lg"></i> New Configuration
                </button>
            </div>
            @if (_qgenSettings.Any())
            {
                <table class="data-table">
                    <thead>
                        <tr>
                            <th>Name</th>
                            <th>Model</th>
                            <th>Endpoint</th>
                            <th>Temperature</th>
                            <th></th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var qs in _qgenSettings)
                        {
                            <tr>
                                <td>
                                    <strong>@qs.Name</strong>
                                    @if (qs.IsDefault)
                                    {
                                        <span class="badge badge-pass ms-2">default</span>
                                    }
                                </td>
                                <td>@(qs.Model)</td>
                                <td style="font-size:12px;max-width:200px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap">@(string.IsNullOrEmpty(qs.Endpoint) ? "—" : qs.Endpoint)</td>
                                <td>@qs.Temperature.ToString("F2")</td>
                                <td>
                                    <button class="btn btn-sm btn-secondary" @onclick="() => OpenEditQGen(qs)">Edit</button>
                                    <button class="btn btn-sm btn-danger" @onclick="() => ConfirmDeleteQGen(qs)">Delete</button>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            }
            else
            {
                <p class="empty-row">No question generation configurations yet. Create one to enable AI-powered test case generation.</p>
            }
        </div>
    }
    else
    {
        <div class="section-card">
            <h2 class="section-title mb-4">@(_editQGen is null ? "New QGen Configuration" : "Edit — " + _qgenForm.Name)</h2>
            <div class="row g-3">
                <div class="col-md-6">
                    <div class="form-group">
                        <label class="form-label">Name *</label>
                        <input class="form-control" @bind="_qgenForm.Name" @bind:event="oninput" placeholder="Default GPT-4o Mini" />
                    </div>
                </div>
                <div class="col-md-6">
                    <div class="form-group">
                        <label class="form-label">Model</label>
                        <input class="form-control" @bind="_qgenForm.Model" @bind:event="oninput" placeholder="gpt-4o-mini" />
                    </div>
                </div>
            </div>
            <div class="row g-3">
                <div class="col-md-6">
                    <div class="form-group">
                        <label class="form-label">Endpoint</label>
                        <input class="form-control" @bind="_qgenForm.Endpoint" @bind:event="oninput" placeholder="https://..." />
                    </div>
                </div>
                <div class="col-md-6">
                    <div class="form-group">
                        <label class="form-label">
                            API Key
                            @if (!string.IsNullOrWhiteSpace(_qgenForm.ApiKeyRef)) {
                                <small class="text-muted ms-1">(configured — enter new to replace)</small>
                            }
                        </label>
                        <input type="password" class="form-control" @bind="_qgenForm.ApiKeyInput" @bind:event="oninput"
                               placeholder="@(string.IsNullOrWhiteSpace(_qgenForm.ApiKeyRef) ? "Enter API key" : "Enter new key to replace current")" autocomplete="new-password" />
                    </div>
                </div>
            </div>
            <div class="row g-3">
                <div class="col-md-3">
                    <div class="form-group">
                        <label class="form-label">Temperature</label>
                        <input class="form-control" type="number" step="0.05" min="0" max="2" @bind="_qgenForm.Temperature" />
                    </div>
                </div>
                <div class="col-md-3">
                    <div class="form-group">
                        <label class="form-label">Top P</label>
                        <input class="form-control" type="number" step="0.05" min="0" max="1" @bind="_qgenForm.TopP" />
                    </div>
                </div>
                <div class="col-md-3">
                    <div class="form-group">
                        <label class="form-label">Max Output Tokens</label>
                        <input class="form-control" type="number" @bind="_qgenForm.MaxOutputTokens" />
                    </div>
                </div>
                <div class="col-md-3">
                    <div class="form-group">
                        <label class="form-label">&nbsp;</label>
                        <div class="form-control bg-transparent border-0 ps-0">
                            <label class="d-flex align-items-center gap-2 mb-0" style="cursor:pointer">
                                <input type="checkbox" @bind="_qgenForm.IsDefault" /> Set as Default
                            </label>
                        </div>
                    </div>
                </div>
            </div>

            <div class="form-group mt-2">
                <div class="d-flex align-items-center gap-2 mb-1">
                    <label class="form-label mb-0">System Prompt <small class="text-muted">(optional — leave blank to use built-in default)</small></label>
                    @if (string.IsNullOrWhiteSpace(_qgenForm.SystemPrompt))
                    {
                        <button class="btn btn-sm btn-outline-secondary" type="button" @onclick="LoadDefaultQGenPromptToForm">
                            <i class="bi bi-clipboard-plus me-1"></i>Load default to edit
                        </button>
                    }
                    else
                    {
                        <button class="btn btn-sm btn-outline-warning" type="button" @onclick="() => _qgenForm.SystemPrompt = null">
                            <i class="bi bi-x-circle me-1"></i>Revert to built-in
                        </button>
                    }
                </div>
                <textarea class="form-control" rows="12" @bind="_qgenForm.SystemPrompt" @bind:event="oninput"
                    style="font-family:monospace;font-size:.85em"
                    placeholder="Leave blank to use the built-in question generation prompt"></textarea>
                <small class="text-muted">Leave blank = built-in prompt. Individual test suites can further override this.</small>
            </div>

            @if (!string.IsNullOrWhiteSpace(_qgenFormError))
            {
                <div class="alert alert-danger mt-2"><i class="bi bi-exclamation-circle me-1"></i>@_qgenFormError</div>
            }
        </div>
        <div class="d-flex gap-2 mb-4">
            <button class="btn btn-primary" @onclick="SaveQGen">
                <i class="bi bi-check-lg"></i> @(_editQGen is null ? "Create Configuration" : "Save Changes")
            </button>
            <button class="btn btn-secondary" disabled="@_qgenTesting" @onclick="TestQGenConnectionAsync">
                @if (_qgenTesting)
                {
                    <span class="spinner me-2"></span>
                }
                else if (_qgenTestPassed.HasValue)
                {
                    @if (_qgenTestPassed.Value)
                    {
                        <i class="bi bi-check-circle-fill text-success me-1"></i>
                    }
                    else
                    {
                        <i class="bi bi-exclamation-triangle-fill text-warning me-1"></i>
                    }
                }
                else
                {
                    <i class="bi bi-wifi me-1"></i>
                }
                Test Connection
            </button>
            <button class="btn btn-secondary" @onclick="CloseQGenForm">
                <i class="bi bi-x-lg"></i> Cancel
            </button>
        </div>
        @if (!string.IsNullOrWhiteSpace(_qgenTestMessage))
        {
            <div class="alert @(_qgenTestPassed == true ? "alert-success" : "alert-warning") mb-4">
                <i class="bi @(_qgenTestPassed == true ? "bi-check-circle" : "bi-exclamation-triangle") me-1"></i>@_qgenTestMessage
            </div>
        }
    }
}

