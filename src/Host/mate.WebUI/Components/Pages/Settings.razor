    private List<RubricSet>    _rubricSets    = [];
    private bool _showJudgeForm;
    private JudgeSetting? _editJudge;
    private JudgeSetting? _deleteJudge;
    private string _judgeFormError = string.Empty;
    private JudgeFormModel _judgeForm = new();
    private bool _judgeTesting;
    private bool? _judgeTestPassed;
    private string _judgeTestMessage = string.Empty;

    // QGen settings
    private bool _qgenTesting;
    private bool? _qgenTestPassed;
    private string _qgenTestMessage = string.Empty;

    // API keys
    private List<ApiKey> _apiKeys = [];
    private bool _showCreateKey;
    private string _newKeyName = string.Empty;
    private string _newKeyRole = "Tester";
    private string? _newRawKey;
    private string _keyError = string.Empty;

    // Audit log
    private List<AuditLogEntity> _auditLogs = [];

    // QGen settings
    private List<GlobalQuestionGenerationSetting> _qgenSettings = [];
    private bool _showQGenForm;
    private GlobalQuestionGenerationSetting? _editQGen;
    private GlobalQuestionGenerationSetting? _deleteQGen;
    private string _qgenFormError = string.Empty;

    private class QGenFormModel
    {
        public string  Name         { get; set; } = string.Empty;
        public string  Endpoint     { get; set; } = string.Empty;
        public string  ApiKeyRef    { get; set; } = string.Empty;
