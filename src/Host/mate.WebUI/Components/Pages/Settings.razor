@if (_tab == "data")
{
    <div class="section-card">
        <h2 class="section-title"><i class="bi bi-database me-2" style="color:var(--primary)"></i>Data Management</h2>
        <p class="text-muted mb-4">Back up the entire application database, restore from a previous backup, or prune old run history to manage database size.</p>

        @if (!string.IsNullOrEmpty(_dataMsg))
        {
            <div class="alert @(_dataOk ? "alert-success" : "alert-danger") mb-3">
                <i class="bi @(_dataOk ? "bi-check-circle" : "bi-exclamation-triangle") me-2"></i>@_dataMsg
            </div>
        }

        @* ── Backup ── *@
        <div class="border rounded p-3 mb-3">
            <h5><i class="bi bi-download me-2"></i>Download Backup</h5>
            <p class="text-muted" style="font-size:13px">In PostgreSQL deployments, database backups are managed at the infrastructure level (Azure Database automated backups or <code>pg_dump</code>). This button is kept for API compatibility but returns an empty file.</p>
            <button class="btn btn-primary" @onclick="TriggerBackupDownload" disabled="@_dataWorking">
                @if (_dataWorking && _dataAction == "backup") { <span class="spinner-border spinner-border-sm me-1"></span> }
                <i class="bi bi-download me-1"></i>Download Backup
            </button>
        </div>

        @* ── Restore ── *@
        <div class="border rounded p-3 mb-3">
            <h5><i class="bi bi-upload me-2"></i>Restore from Backup</h5>
            <p class="text-muted" style="font-size:13px">Database restore is not supported in PostgreSQL mode. Use <code>pg_restore</code> or the Azure Database Console to restore from a backup.</p>
            <div class="alert alert-warning mb-3" style="font-size:13px">
                <i class="bi bi-exclamation-triangle me-2"></i>
                <strong>Warning:</strong> This will permanently overwrite all current data — agents, test suites, runs, results, and settings. This action cannot be undone.
            </div>
            <InputFile OnChange="OnRestoreFileSelected" accept="*" class="form-control mb-2" style="max-width:400px" />
            @if (_restoreFile != null && !_restoreConfirming)
            {
                <div class="text-muted mb-2" style="font-size:13px">
                    <i class="bi bi-file-earmark-binary me-1"></i>
                    Selected: <strong>@_restoreFile.Name</strong> (@((_restoreFile.Size / 1024.0).ToString("F1")) KB)
                </div>
                <button class="btn btn-danger" @onclick='() => _restoreConfirming = true'>
                    <i class="bi bi-upload me-1"></i>Restore
                </button>
            }
            @if (_restoreConfirming)
            {
                <div class="alert alert-danger mb-2" style="font-size:13px">
                    <i class="bi bi-shield-exclamation me-2"></i>
                    <strong>Are you sure?</strong> Restoring <strong>@_restoreFile?.Name</strong> will replace all current data and reload the application.
                </div>
                <div class="d-flex gap-2">
                    <button class="btn btn-danger" @onclick="PerformRestore" disabled="@_dataWorking">
                        @if (_dataWorking && _dataAction == "restore") { <span class="spinner-border spinner-border-sm me-1"></span><span>Restoring&hellip;</span> }
                        else { <i class="bi bi-check-lg me-1"></i><span>Confirm Restore</span> }
                    </button>
                    <button class="btn btn-outline-secondary" @onclick="CancelRestore" disabled="@_dataWorking">
                        <i class="bi bi-x-lg me-1"></i>Cancel
                    </button>
                </div>
            }
        </div>

        @* ── Pruning ── *@
        <div class="border rounded p-3">
            <h5><i class="bi bi-scissors me-2"></i>Run History Pruning</h5>
            <p class="text-muted" style="font-size:13px">Delete completed runs older than a specified number of days to keep the database size manageable. Runs currently in progress are never deleted.</p>
            <div class="d-flex align-items-center gap-3 flex-wrap mb-2">
                <label class="mb-0" style="font-size:14px;white-space:nowrap">Delete runs older than</label>
                <input type="number" class="form-control" style="width:100px" min="1" max="3650"
                       @bind="_pruningDays" @bind:event="oninput" />
                <label class="mb-0" style="font-size:14px">days</label>
                <button class="btn btn-warning" @onclick="PruneRuns" disabled="@_dataWorking">
                    @if (_dataWorking && _dataAction == "prune") { <span class="spinner-border spinner-border-sm me-1"></span><span>Pruning&hellip;</span> }
                    else { <i class="bi bi-trash me-1"></i><span>Prune Now</span> }
                </button>
            </div>
            @if (!string.IsNullOrEmpty(_pruneResult))
            {
                <div class="alert @(_pruneResult.StartsWith("✓") ? "alert-success" : "alert-info") mb-0" style="font-size:13px">@_pruneResult</div>
            }
        </div>
    </div>
}

@* ── Authentication ─────────────────────────────────────────────────────── *@
@if (_tab == "auth")
{
    <div class="section-card">
        <div class="section-header mb-3">
            <span class="section-title">Authentication</span>
            @if (_authScheme is "None" or "Generic")
            {
                <span class="connector-badge" style="background:var(--warning);color:#fff">Development Mode</span>
            }
            else if (_authScheme is "EntraId" or "OAuth")
            {
                <span class="badge badge-pass">Production</span>
            }
            else
            {
                <span class="connector-badge">@_authScheme</span>
            }
        </div>
        <p class="text-muted mb-4" style="font-size:13px">
            The active authentication scheme is controlled by <code>Authentication:Scheme</code> in <code>appsettings.json</code>
            or the environment variable <code>Authentication__Scheme</code>.
        </p>
        <table class="data-table mb-4" style="max-width:640px">
            <tbody>
                <tr>
                    <td style="font-weight:600;width:160px">Active Scheme</td>
                    <td><code>@_authScheme</code></td>
                </tr>
                <tr>
                    <td style="font-weight:600">Module</td>
                    <td>@AuthModuleDisplayName(_authScheme)</td>
                </tr>
                <tr>
                    <td style="font-weight:600">Description</td>
                    <td style="font-size:13px">@AuthSchemeDescription(_authScheme)</td>
                </tr>
            </tbody>
        </table>

        @if (_authScheme is "None" or "Generic")
        {
            <div class="alert alert-warning mb-4" style="font-size:13px">
                <i class="bi bi-exclamation-triangle me-2"></i>
                <strong>Development mode active.</strong> All requests are automatically authenticated as SuperAdmin.
                This mode must not be used in production.
            </div>
        }

        <div class="border rounded p-3 mb-3">
            <h5 style="font-size:14px;font-weight:600;margin-bottom:8px"><i class="bi bi-microsoft me-2"></i>Switch to Microsoft Entra ID</h5>
            <p class="text-muted" style="font-size:13px">Set in your environment or <code>appsettings.json</code>:</p>
            <pre style="font-size:12px;background:var(--light-bg);border-radius:6px;padding:10px;overflow-x:auto;margin:0">Authentication__Scheme=EntraId
AzureAd__TenantId=&lt;your-tenant-id&gt;
AzureAd__ClientId=&lt;your-client-id&gt;</pre>
        </div>

        <div class="border rounded p-3">
            <h5 style="font-size:14px;font-weight:600;margin-bottom:8px"><i class="bi bi-shield-check me-2"></i>Switch to OAuth 2.0 / OIDC</h5>
            <p class="text-muted" style="font-size:13px">For Okta, Auth0, Keycloak, or any OIDC-compliant provider:</p>
            <pre style="font-size:12px;background:var(--light-bg);border-radius:6px;padding:10px;overflow-x:auto;margin:0">Authentication__Scheme=OAuth
OAuth__Authority=https://your-idp.com
OAuth__Audience=your-api-audience</pre>
        </div>
    </div>
}

</div>@* end mate-page *@

@code {
