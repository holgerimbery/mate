    private async Task TestJudgeConnectionAsync()
    {
        _judgeTesting = true;
        _judgeTestPassed = null;
        _judgeTestMessage = string.Empty;
        StateHasChanged();
        try
        {
            if (string.IsNullOrWhiteSpace(_judgeForm.EndpointRef))
            {
                _judgeTestPassed = false;
                _judgeTestMessage = "Endpoint Ref is required to test the connection.";
                return;
            }
            string endpoint;
            try { endpoint = await SecretSvc.GetSecretAsync(_judgeForm.EndpointRef); }
            catch { endpoint = _judgeForm.EndpointRef; }

            string apiKey;
            if (!string.IsNullOrWhiteSpace(_judgeForm.ApiKeyInput))
            {
                apiKey = _judgeForm.ApiKeyInput;
            }
            else if (!string.IsNullOrWhiteSpace(_judgeForm.ApiKeyRef))
            {
                try { apiKey = await SecretSvc.GetSecretAsync(_judgeForm.ApiKeyRef); }
                catch { apiKey = _judgeForm.ApiKeyRef; }
            }
            else
            {
                _judgeTestPassed = false;
                _judgeTestMessage = "API key is required to test the connection.";
                return;
            }

            var model = _judgeForm.Model ?? "gpt-4o-mini";
            await PingLlmAsync(endpoint, apiKey, model);
            _judgeTestPassed = true;
            _judgeTestMessage = $"Connection successful! Model: {model}";
        }
        catch (Exception ex)
        {
            _judgeTestPassed = false;
            _judgeTestMessage = $"Connection failed: {ex.Message}";
        }
        finally
        {
            _judgeTesting = false;
        }
    }

