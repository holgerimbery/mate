    }

    private void OnRestoreFileSelected(Microsoft.AspNetCore.Components.Forms.InputFileChangeEventArgs e)
    {
        _restoreFile      = e.File;
        _restoreConfirming = false;
        _dataMsg           = "";
    }

    private void CancelRestore()
    {
        _restoreConfirming = false;
        _restoreFile       = null;
        _dataMsg           = "";
    }

    private async Task PerformRestore()
    {
        if (_restoreFile is null) return;
        _dataWorking = true;
        _dataAction  = "restore";
        _dataMsg     = "";
        StateHasChanged();
        try
        {
            const long maxBytes = 500L * 1024 * 1024;
            using var content = new System.Net.Http.MultipartFormDataContent();
            var stream = _restoreFile.OpenReadStream(maxAllowedSize: maxBytes);
            content.Add(new System.Net.Http.StreamContent(stream), "file", _restoreFile.Name);
            var client = HttpClientFactory.CreateClient();
            var baseUri = NavigationManager.BaseUri.TrimEnd('/');
            var resp = await client.PostAsync(baseUri + "/api/admin/restore", content);
            if (!resp.IsSuccessStatusCode)
            {
                var err = await resp.Content.ReadAsStringAsync();
                throw new InvalidOperationException(err);
            }
            NavigationManager.NavigateTo("/", forceLoad: true);
        }
        catch (Exception ex)
        {
            _dataMsg = $"Restore failed: {ex.Message}";
            _dataOk  = false;
            _dataWorking = false;
            _dataAction  = "";
            _restoreConfirming = false;
        }
    }

    private async Task PruneRuns()
    {
        if (_pruningDays < 1) { _pruneResult = "Enter a value of at least 1 day."; return; }
        _dataWorking = true;
        _dataAction  = "prune";
        _pruneResult = "";
        StateHasChanged();
        try
        {
            var cutoff   = DateTime.UtcNow.AddDays(-_pruningDays);
            var toDelete = await Db.Runs
                .Where(r => r.StartedAt < cutoff && (r.Status == "completed" || r.Status == "failed"))
                .ToListAsync();
            if (toDelete.Count == 0)
            {
                _pruneResult = $"No runs found older than {_pruningDays} days.";
            }
            else
            {
                var runIds = toDelete.Select(r => r.Id).ToList();
                var resultCount = await Db.Results.CountAsync(r => runIds.Contains(r.RunId));
                var transcriptCount = await Db.TranscriptMessages
                    .Join(Db.Results, t => t.ResultId, r => r.Id, (t, r) => new { t, r.RunId })
                    .CountAsync(x => runIds.Contains(x.RunId));

                Db.Runs.RemoveRange(toDelete);
                await Db.SaveChangesAsync();
                _pruneResult = $"\u2713 Deleted {toDelete.Count} run(s), {resultCount} result(s), and {transcriptCount} transcript message(s) older than {_pruningDays} days.";
            }
        }
        catch (Exception ex)
        {
            _pruneResult = $"Error: {ex.Message}";
        }
        finally
        {
            _dataWorking = false;
            _dataAction  = "";
        }
    }
