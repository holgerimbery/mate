@attribute [Authorize]
@page "/rubrics"
@using mate.Data
@using mate.Domain.Entities
@using Microsoft.EntityFrameworkCore
@inject mateDbContext Db
@inject ITenantContext TenantCtx

<PageTitle>Rubrics — @BrandInfo.BrandName</PageTitle>

@if (!_showForm)
{
    <div class="mate-header">
        <h1>Rubrics</h1>
        <p>Define deterministic evaluation criteria for scoring agent responses without an LLM.</p>
    </div>
    <div class="mate-page">
        @if (!string.IsNullOrEmpty(_error))
        {
            <div class="alert alert-danger mb-3"><i class="bi bi-exclamation-circle me-1"></i>@_error
                <button type="button" class="btn-close float-end" @onclick='() => _error = string.Empty'></button>
            </div>
        }
        <div class="section-card">
            <div class="section-header">
                <span class="section-title">All Rubric Sets</span>
                <button class="btn btn-primary btn-sm" @onclick="OpenNewRubricSet">
                    <i class="bi bi-plus-lg me-1"></i>New Rubric Set
                </button>
            </div>
            @if (_loading)
            {
                <p><em>Loading…</em></p>
            }
            else
            {
                <table class="data-table">
                    <thead>
                        <tr>
                            <th>Name</th>
                            <th>Linked Judge</th>
                            <th>Description</th>
                            <th>Criteria</th>
                            <th>Mandatory Override</th>
                            <th>Created</th>
                            <th></th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var rs in _rubricSets)
                        {
                            <tr>
                                <td>
                                    <strong>@rs.Name</strong>
                                    @if (rs.IsDraft) { <span class="badge badge-premium ms-2" style="font-size:10px;vertical-align:middle">DRAFT</span> }
                                </td>
                                <td style="font-size:13px">
                                    @{ var linkedJudge = _judgeSettings.FirstOrDefault(j => j.Id == rs.JudgeSettingId); }
                                    @if (linkedJudge is not null)
                                    {
                                        <span class="connector-badge">@linkedJudge.Name</span>
                                    }
                                    else
                                    {
                                        <span style="color:var(--text-secondary)">&#x2014;</span>
                                    }
                                </td>
                                <td style="font-size:13px;color:var(--text-secondary)">@(rs.Description?.Length > 80 ? rs.Description[..78] + "…" : rs.Description ?? "—")</td>
                                <td>
                                    <span class="connector-badge">@rs.Criteria.Count criterion@(rs.Criteria.Count == 1 ? "" : "a")</span>
                                </td>
                                <td>@(rs.RequireAllMandatory ? "Yes — mandatory fail overrides score" : "No")</td>
                                <td style="font-size:12px">@rs.CreatedAt.ToString("yyyy-MM-dd")</td>
                                <td>
                                    <button class="btn btn-sm btn-secondary" @onclick="() => OpenEdit(rs)"><i class="bi bi-pencil me-1"></i>Edit</button>
                                    <button class="btn btn-sm btn-secondary" @onclick="() => OpenCriteria(rs)"><i class="bi bi-list-nested me-1"></i>Criteria</button>
                                    @if (rs.IsDraft)
                                    {
                                        <button class="btn btn-sm btn-primary" @onclick="() => PromoteRubricSet(rs)" title="Remove draft flag — make this rubric set active"><i class="bi bi-check2-circle me-1"></i>Promote</button>
                                    }
                                    <button class="btn btn-sm btn-secondary" @onclick="() => CloneRubricSet(rs)" title="Clone"><i class="bi bi-copy"></i></button>
                                    <button class="btn btn-sm btn-danger" @onclick="() => ConfirmDelete(rs)"><i class="bi bi-trash"></i></button>
                                </td>
                            </tr>
                        }
                        @if (!_rubricSets.Any())
                        {
                            <tr><td colspan="6" class="empty-row">No rubric sets configured yet.</td></tr>
                        }
                    </tbody>
                </table>
            }
        </div>
    </div>
}
else if (_formMode == "set")
{
    <!-- Edit / New Rubric Set -->
    <div class="mate-header">
        <h1>@(_editSetId.HasValue ? "Edit Rubric Set" : "New Rubric Set")</h1>
        <p>@(_editSetId.HasValue ? "Update the rubric set name, description, and scoring options." : "Define a new set of weighted evaluation criteria.")</p>
    </div>
    <div class="mate-page">
        <div class="section-card">
            <div class="form-group">
                <label class="form-label">Judge Setting *</label>
                <select class="form-control" @bind="_setForm.JudgeSettingId">
                    <option value="">&#x2014; Select a judge setting &#x2014;</option>
                    @foreach (var js in _judgeSettings)
                    {
                        <option value="@js.Id">@js.Name (@js.ProviderType)@(js.IsDefault ? " [default]" : "")</option>
                    }
                </select>
                <small class="text-muted">The judge that will use this rubric set. Must be type Rubrics, Hybrid, or CopilotStudioJudge.</small>
            </div>
            <div class="form-group">
                <label class="form-label">Name *</label>
                <input class="form-control" @bind="_setForm.Name" placeholder="e.g. Safety Criteria" />
            </div>
            <div class="form-group">
                <label class="form-label">Description</label>
                <input class="form-control" @bind="_setForm.Description" placeholder="Optional description" />
            </div>
            <div class="form-group">
                <label class="form-label d-flex align-items-center gap-2">
                    <input type="checkbox" @bind="_setForm.RequireAllMandatory" />
                    Require All Mandatory Criteria — any mandatory failure overrides the weighted score to Fail
                </label>
            </div>
            @if (!string.IsNullOrEmpty(_formError))
            {
                <div class="alert alert-danger mt-2">@_formError</div>
            }
            <div class="d-flex gap-2 mt-3">
                <button class="btn btn-primary" @onclick="SaveRubricSet"><i class="bi bi-check-lg me-1"></i>@(_editSetId.HasValue ? "Save Changes" : "Create Rubric Set")</button>
                <button class="btn btn-secondary" @onclick="CloseForm"><i class="bi bi-x-lg me-1"></i>Cancel</button>
            </div>
        </div>
    </div>
}
else if (_formMode == "criteria" && _selectedRubricSet is not null)
{
    <!-- Manage Criteria for a Rubric Set -->
    <div class="mate-header">
        <h1>Criteria — @_selectedRubricSet.Name</h1>
        <p>Add, edit, and reorder evaluation criteria for this rubric set.</p>
    </div>
    <div class="mate-page">
        <div class="d-flex justify-content-end mb-3">
            <button class="btn btn-secondary" @onclick="CloseForm"><i class="bi bi-arrow-left me-1"></i>Back to Rubrics</button>
        </div>
        @if (!string.IsNullOrEmpty(_formError))
        {
            <div class="alert alert-danger mb-3">@_formError</div>
        }

        <!-- Add / Edit criterion form -->
        <div class="section-card mb-3">
            <h2 class="section-title mb-3">@(_editCriterionId.HasValue ? "Edit Criterion" : "Add Criterion")</h2>
            <div class="row g-3">
                <div class="col-md-6">
                    <div class="form-group">
                        <label class="form-label">Name *</label>
                        <input class="form-control" @bind="_criterionForm.Name" placeholder="e.g. Mentions refund policy" />
                    </div>
                </div>
                <div class="col-md-6">
                    <div class="form-group">
                        <label class="form-label">Evaluation Type</label>
                        <select class="form-control" @bind="_criterionForm.EvaluationType">
                            <option value="Contains">Contains — response must include substring</option>
                            <option value="NotContains">NotContains — response must NOT include substring</option>
                            <option value="Regex">Regex — response must match regex</option>
                            <option value="Custom">Custom — resolved by custom code</option>
                        </select>
                    </div>
                </div>
                <div class="col-md-8">
                    <div class="form-group">
                        <label class="form-label">Pattern *</label>
                        <input class="form-control" @bind="_criterionForm.Pattern" placeholder="Substring, regex pattern, or custom key" />
                    </div>
                </div>
                <div class="col-md-2">
                    <div class="form-group">
                        <label class="form-label">Weight</label>
                        <input type="number" class="form-control" @bind="_criterionForm.Weight" min="0" max="10" step="0.1" />
                    </div>
                </div>
                <div class="col-md-2">
                    <div class="form-group">
                        <label class="form-label">Sort Order</label>
                        <input type="number" class="form-control" @bind="_criterionForm.SortOrder" min="0" />
                    </div>
                </div>
                <div class="col-12">
                    <label class="form-label d-flex align-items-center gap-2">
                        <input type="checkbox" @bind="_criterionForm.IsMandatory" />
                        Mandatory — failure of this criterion forces overall result to Fail (when Require All Mandatory is enabled)
                    </label>
                </div>
            </div>
            @if (!string.IsNullOrEmpty(_criterionError))
            {
                <div class="alert alert-danger mt-2">@_criterionError</div>
            }
            <div class="d-flex gap-2 mt-3">
                <button class="btn btn-primary" @onclick="SaveCriterion">
                    <i class="bi bi-check-lg me-1"></i>@(_editCriterionId.HasValue ? "Update Criterion" : "Add Criterion")
                </button>
                @if (_editCriterionId.HasValue)
                {
                    <button class="btn btn-secondary" @onclick="ClearCriterionForm"><i class="bi bi-x-lg me-1"></i>Cancel Edit</button>
                }
            </div>
        </div>

        <!-- Criteria list -->
        @if (_selectedRubricSet.Criteria.Any())
        {
            <div class="section-card">
                <h2 class="section-title mb-3">Criteria (@_selectedRubricSet.Criteria.Count)</h2>
                <table class="data-table">
                    <thead>
                        <tr>
                            <th style="width:50px">#</th>
                            <th>Name</th>
                            <th>Type</th>
                            <th>Pattern</th>
                            <th style="width:80px">Weight</th>
                            <th style="width:90px">Mandatory</th>
                            <th style="width:100px"></th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var c in _selectedRubricSet.Criteria.OrderBy(x => x.SortOrder))
                        {
                            <tr>
                                <td style="font-size:12px;color:var(--text-secondary)">@c.SortOrder</td>
                                <td><strong>@c.Name</strong></td>
                                <td><span class="connector-badge">@c.EvaluationType</span></td>
                                <td><code style="font-size:11px">@c.Pattern</code></td>
                                <td>@c.Weight.ToString("F2")</td>
                                <td>@(c.IsMandatory ? "✓ Mandatory" : "—")</td>
                                <td>
                                    <button class="btn btn-sm btn-secondary" @onclick="() => EditCriterion(c)"><i class="bi bi-pencil"></i></button>
                                    <button class="btn btn-sm btn-danger" @onclick="() => DeleteCriterion(c)"><i class="bi bi-trash"></i></button>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
        else
        {
            <div class="empty-state">
                <i class="bi bi-list-check"></i>
                <h3>No criteria yet</h3>
                <p>Add criteria above to define how responses are evaluated.</p>
            </div>
        }
    </div>
}

<!-- Delete confirmation modal -->
@if (_deleteTarget is not null)
{
    <div class="modal-backdrop" @onclick="() => _deleteTarget = null">
        <div class="modal-box" @onclick:stopPropagation>
            <h2>Delete Rubric Set</h2>
            <p>Delete <strong>@_deleteTarget.Name</strong> and all its criteria? This cannot be undone.</p>
            <div class="modal-actions">
                <button class="btn btn-danger" @onclick="DeleteRubricSet">Delete</button>
                <button class="btn btn-secondary" @onclick="() => _deleteTarget = null">Cancel</button>
            </div>
        </div>
    </div>
}

@code {
    private bool _showForm;
    private string _formMode = ""; // "set" | "criteria"

    private bool _loading;
    private string _error = string.Empty;
    private List<RubricSet> _rubricSets = [];
    private List<JudgeSetting> _judgeSettings = [];

    private Guid? _editSetId;
    private RubricSet? _selectedRubricSet;
    private RubricSet? _deleteTarget;

    private class SetForm
    {
        public string  Name                { get; set; } = string.Empty;
        public string? Description         { get; set; }
        public bool    RequireAllMandatory { get; set; }
        public string  JudgeSettingId      { get; set; } = string.Empty;
    }

    private class CriterionForm
    {
        public string Name            { get; set; } = string.Empty;
        public string EvaluationType  { get; set; } = "Contains";
        public string Pattern         { get; set; } = string.Empty;
        public double Weight          { get; set; } = 1.0;
        public bool   IsMandatory     { get; set; }
        public int    SortOrder       { get; set; }
    }

    private SetForm       _setForm       = new();
    private string        _formError     = string.Empty;
    private CriterionForm _criterionForm = new();
    private string        _criterionError = string.Empty;
    private Guid?         _editCriterionId;

    protected override async Task OnInitializedAsync() => await LoadAsync();

    private async Task LoadAsync()
    {
        _loading = true;
        try
        {
            _rubricSets = await Db.RubricSets
                .Include(r => r.Criteria)
                .OrderBy(r => r.Name)
                .ToListAsync();
            _judgeSettings = await Db.JudgeSettings
                .OrderBy(j => j.Name)
                .ToListAsync();
        }
        catch (Exception ex) { _error = ex.Message; }
        finally { _loading = false; }
    }

    // ── RubricSet CRUD ────────────────────────────────────────────────────────

    private void OpenNewRubricSet()
    {
        _editSetId  = null;
        _setForm    = new();
        _formError  = string.Empty;
        _formMode   = "set";
        _showForm   = true;
    }

    private void OpenEdit(RubricSet rs)
    {
        _editSetId = rs.Id;
        _setForm   = new() { Name = rs.Name, Description = rs.Description, RequireAllMandatory = rs.RequireAllMandatory, JudgeSettingId = rs.JudgeSettingId == Guid.Empty ? string.Empty : rs.JudgeSettingId.ToString() };
        _formError = string.Empty;
        _formMode  = "set";
        _showForm  = true;
    }

    private void OpenCriteria(RubricSet rs)
    {
        _selectedRubricSet = rs;
        ClearCriterionForm();
        _formMode  = "criteria";
        _showForm  = true;
    }

    private void CloseForm()
    {
        _showForm         = false;
        _formMode         = "";
        _selectedRubricSet = null;
        _formError        = string.Empty;
        _criterionError   = string.Empty;
    }

    private async Task SaveRubricSet()
    {
        if (string.IsNullOrWhiteSpace(_setForm.Name)) { _formError = "Name is required."; return; }

        var judgeId = Guid.TryParse(_setForm.JudgeSettingId, out var jg) ? jg : Guid.Empty;

        try
        {
            if (_editSetId.HasValue)
            {
                var rs = _rubricSets.First(r => r.Id == _editSetId.Value);
                rs.Name                = _setForm.Name;
                rs.Description         = _setForm.Description ?? string.Empty;
                rs.RequireAllMandatory = _setForm.RequireAllMandatory;
                rs.JudgeSettingId      = judgeId;
            }
            else
            {
                Db.RubricSets.Add(new RubricSet
                {
                    Id                  = Guid.NewGuid(),
                    TenantId            = TenantCtx.TenantId,
                    JudgeSettingId      = judgeId,
                    Name                = _setForm.Name,
                    Description         = _setForm.Description ?? string.Empty,
                    RequireAllMandatory = _setForm.RequireAllMandatory,
                    CreatedAt           = DateTime.UtcNow
                });
            }
            await Db.SaveChangesAsync();
            CloseForm();
            await LoadAsync();
        }
        catch (Exception ex) { _formError = ex.Message; }
    }

    private async Task CloneRubricSet(RubricSet source)
    {
        try
        {
            var clone = new RubricSet
            {
                Id                  = Guid.NewGuid(),
                TenantId            = TenantCtx.TenantId,
                JudgeSettingId      = source.JudgeSettingId,
                Name                = source.Name + " (Copy)",
                Description         = source.Description,
                RequireAllMandatory = source.RequireAllMandatory,
                CreatedAt           = DateTime.UtcNow,
            };
            foreach (var c in source.Criteria)
            {
                clone.Criteria.Add(new RubricCriteria
                {
                    Id             = Guid.NewGuid(),
                    RubricSetId    = clone.Id,
                    TenantId       = TenantCtx.TenantId,
                    Name           = c.Name,
                    EvaluationType = c.EvaluationType,
                    Pattern        = c.Pattern,
                    Weight         = c.Weight,
                    IsMandatory    = c.IsMandatory,
                    SortOrder      = c.SortOrder,
                });
            }
            Db.RubricSets.Add(clone);
            await Db.SaveChangesAsync();
            await LoadAsync();
        }
        catch (Exception ex) { _error = ex.Message; }
    }

    private void ConfirmDelete(RubricSet rs) => _deleteTarget = rs;

    private async Task PromoteRubricSet(RubricSet rs)
    {
        try
        {
            rs.IsDraft = false;
            await Db.SaveChangesAsync();
            await LoadAsync();
        }
        catch (Exception ex) { _error = ex.Message; }
    }

    private async Task DeleteRubricSet()
    {
        if (_deleteTarget is null) return;
        Db.RubricSets.Remove(_deleteTarget);
        await Db.SaveChangesAsync();
        _deleteTarget = null;
        await LoadAsync();
    }

    // ── Criteria CRUD ─────────────────────────────────────────────────────────

    private void EditCriterion(RubricCriteria c)
    {
        _editCriterionId = c.Id;
        _criterionForm   = new()
        {
            Name           = c.Name,
            EvaluationType = c.EvaluationType,
            Pattern        = c.Pattern,
            Weight         = c.Weight,
            IsMandatory    = c.IsMandatory,
            SortOrder      = c.SortOrder
        };
        _criterionError = string.Empty;
    }

    private async Task SaveCriterion()
    {
        if (string.IsNullOrWhiteSpace(_criterionForm.Name))    { _criterionError = "Name is required.";    return; }
        if (string.IsNullOrWhiteSpace(_criterionForm.Pattern)) { _criterionError = "Pattern is required."; return; }
        if (_selectedRubricSet is null) return;

        if (_editCriterionId.HasValue)
        {
            var existing = _selectedRubricSet.Criteria.First(c => c.Id == _editCriterionId.Value);
            existing.Name           = _criterionForm.Name;
            existing.EvaluationType = _criterionForm.EvaluationType;
            existing.Pattern        = _criterionForm.Pattern;
            existing.Weight         = _criterionForm.Weight;
            existing.IsMandatory    = _criterionForm.IsMandatory;
            existing.SortOrder      = _criterionForm.SortOrder;
        }
        else
        {
            _selectedRubricSet.Criteria.Add(new RubricCriteria
            {
                Id             = Guid.NewGuid(),
                RubricSetId    = _selectedRubricSet.Id,
                TenantId       = TenantCtx.TenantId,
                Name           = _criterionForm.Name,
                EvaluationType = _criterionForm.EvaluationType,
                Pattern        = _criterionForm.Pattern,
                Weight         = _criterionForm.Weight,
                IsMandatory    = _criterionForm.IsMandatory,
                SortOrder      = _criterionForm.SortOrder
            });
        }
        await Db.SaveChangesAsync();
        ClearCriterionForm();
        await LoadAsync();
        _selectedRubricSet = _rubricSets.FirstOrDefault(r => r.Id == _selectedRubricSet.Id);
    }

    private async Task DeleteCriterion(RubricCriteria c)
    {
        if (_selectedRubricSet is null) return;
        Db.RubricCriterias.Remove(c);
        await Db.SaveChangesAsync();
        await LoadAsync();
        _selectedRubricSet = _rubricSets.FirstOrDefault(r => r.Id == _selectedRubricSet?.Id);
    }

    private void ClearCriterionForm()
    {
        _editCriterionId = null;
        _criterionForm   = new();
        _criterionError  = string.Empty;
    }
}
