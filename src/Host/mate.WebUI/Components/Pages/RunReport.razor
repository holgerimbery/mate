@implements IDisposable
@attribute [Authorize]
@page "/runs/{RunId:guid}"
@using mate.Data
@using mate.Domain.Entities
@using Microsoft.EntityFrameworkCore
@using System.Text
@using Markdig
@inject mateDbContext Db
@inject NavigationManager Nav
@inject IJSRuntime JS

<PageTitle>Run Report — @BrandInfo.BrandName</PageTitle>

@if (_loading)
{
    <div class="mate-page"><div class="d-flex align-items-center gap-2 py-4"><span class="spinner"></span><span>Loading report…</span></div></div>
}
else if (_run is null)
{
    <div class="mate-page"><div class="alert alert-warning">Run not found. <a href="/dashboard">← Back to Dashboard</a></div></div>
}
else
{
    <!-- Page header with breadcrumb -->
    <div class="mate-header">
        <div>
            <nav style="font-size:13px;color:var(--text-secondary);margin-bottom:6px">
                <a href="/dashboard" style="color:var(--primary);text-decoration:none;font-weight:500">Dashboard</a>
                <span style="margin:0 6px;color:var(--text-tertiary)">/</span>
                <span>Run Report</span>
            </nav>
            <h1>@(_run.Suite?.Name ?? "Test Suite") — Run Report</h1>
            <p>Executed @_run.StartedAt.ToString("MMMM dd, yyyy \\a\\t HH:mm:ss")</p>
        </div>
        <div class="d-flex gap-2 align-items-center" style="flex-shrink:0">
            <button class="btn btn-secondary" @onclick="ExportCsv">
                <i class="bi bi-download me-1"></i>Export CSV
            </button>
            <a href="/dashboard" class="btn btn-secondary">
                <i class="bi bi-chevron-left me-1"></i>Dashboard
            </a>
        </div>
    </div>
    @if (_transcriptResult is null && _verdictResult is null)
    {
    <div class="mate-page">

    @* ── Live progress (pending / running) ───────────────────────── *@
    @if (_run.Status is "pending" or "running")
    {
        var _completed = _results.Count;
        var _total     = _run.TotalTestCases > 0 ? _run.TotalTestCases : 1;
        var _pct       = Math.Min(100, (int)(100.0 * _completed / _total));
        <div class="section-card mb-3" style="border-left:4px solid var(--primary)">
            <div class="d-flex align-items-center gap-3 mb-2">
                <span class="spinner"></span>
                <span style="font-weight:600">
                    @if (_run.Status == "pending")
                    {
                        <span>Waiting for worker to pick up run&hellip;</span>
                    }
                    else
                    {
                        <span>Run in progress &mdash; @_completed&nbsp;/&nbsp;@_run.TotalTestCases tests completed</span>
                    }
                </span>
            </div>
            @if (_run.Status == "running" && _run.TotalTestCases > 0)
            {
                <div style="background:var(--border);border-radius:4px;height:8px;overflow:hidden;margin-bottom:8px">
                    <div style="height:100%;border-radius:4px;background:var(--primary);width:@(_pct)%;transition:width 0.4s ease"></div>
                </div>
                @if (_results.Any())
                {
                    <div class="d-flex flex-wrap gap-1 mt-2">
                        @foreach (var _pr in _results.TakeLast(10))
                        {
                            <span class="badge badge-@_pr.Verdict" title="@_pr.TestCase?.Name">@(_pr.TestCase?.Name is { Length: > 20 } n ? n[..18] + "\u2026" : _pr.TestCase?.Name ?? "\u2014")</span>
                        }
                    </div>
                }
            }
        </div>
    }

    <!-- Summary KPI cards -->
    <div class="kpi-grid" style="margin-bottom:24px">
        <div class="kpi-card">
            <div class="kpi-value">@(_results.Any() ? (_results.Average(r => r.OverallScore) * 100).ToString("F1") + "%" : "—")</div>
            <div class="kpi-label">Overall Score</div>
        </div>
        <div class="kpi-card kpi-pass">
            <div class="kpi-value">@(_run.TotalTestCases > 0 ? $"{(double)_run.PassedCount / _run.TotalTestCases:P0}" : "—")</div>
            <div class="kpi-label">Pass Rate</div>
        </div>
        <div class="kpi-card">
            <div class="kpi-value"><span style="color:var(--success)">@_run.PassedCount</span> / <span style="color:var(--danger)">@_run.FailedCount</span></div>
            <div class="kpi-label">Pass / Fail</div>
        </div>
        <div class="kpi-card">
            <div class="kpi-value">@($"{_run.AverageLatencyMs:N0} ms")</div>
            <div class="kpi-label">Avg Latency</div>
        </div>
    </div>

    <!-- Run details -->
    <div class="section-card" style="margin-bottom:20px">
        <h2 class="section-title mb-3"><i class="bi bi-info-circle me-2"></i>Run Details</h2>
        <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(180px,1fr));gap:20px;font-size:14px">
            <div>
                <div style="color:var(--text-secondary);font-weight:500;margin-bottom:4px">Suite</div>
                <div style="font-weight:600">@(_run.Suite?.Name ?? "—")</div>
            </div>
            <div>
                <div style="color:var(--text-secondary);font-weight:500;margin-bottom:4px">Agent</div>
                <div style="font-weight:600">@(_run.Agent?.Name ?? "—")</div>
            </div>
            <div>
                <div style="color:var(--text-secondary);font-weight:500;margin-bottom:4px">Started</div>
                <div style="font-weight:600">@_run.StartedAt.ToString("MMM dd, HH:mm:ss")</div>
            </div>
            <div>
                <div style="color:var(--text-secondary);font-weight:500;margin-bottom:4px">Duration</div>
                <div style="font-weight:600">
                    @if (_run.CompletedAt.HasValue)
                    {
                        <span>@((_run.CompletedAt.Value - _run.StartedAt).TotalSeconds.ToString("F1"))s</span>
                    }
                    else
                    {
                        <span style="color:var(--warning)">In Progress</span>
                    }
                </div>
            </div>
            <div>
                <div style="color:var(--text-secondary);font-weight:500;margin-bottom:4px">Status</div>
                <div><span class="badge badge-@_run.Status">@_run.Status</span></div>
            </div>

            @if (!string.IsNullOrWhiteSpace(_run.RequestedBy))
            {
                <div>
                    <div style="color:var(--text-secondary);font-weight:500;margin-bottom:4px">Requested by</div>
                    <div style="font-weight:600">@_run.RequestedBy</div>
                </div>
            }
        </div>
    </div>

    <!-- Score breakdown -->
    @if (_results.Any())
    {
        var avgTask       = _results.Average(r => r.TaskSuccessScore);
        var avgIntent     = _results.Average(r => r.IntentMatchScore);
        var avgFactuality = _results.Average(r => r.FactualityScore);
        var avgHelpful    = _results.Average(r => r.HelpfulnessScore);
        var avgSafety     = _results.Average(r => r.SafetyScore);

        <div class="section-card" style="margin-bottom:20px">
            <h2 class="section-title mb-3"><i class="bi bi-graph-up me-2"></i>Score Breakdown</h2>
            <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(260px,1fr));gap:16px">
                @foreach (var (label, val) in new[]{("Task Success", avgTask),("Intent Match", avgIntent),("Factuality", avgFactuality),("Helpfulness", avgHelpful),("Safety", avgSafety)})
                {
                    <div>
                        <div style="display:flex;justify-content:space-between;font-size:13px;margin-bottom:4px">
                            <span style="color:var(--text-secondary)">@label</span>
                            <strong style="color:var(--primary)">@val.ToString("P0")</strong>
                        </div>
                        <div style="background:var(--light-bg);border-radius:4px;height:8px;overflow:hidden">
                            <div style="height:100%;border-radius:4px;background:var(--primary);width:@((val*100).ToString("F1"))%"></div>
                        </div>
                    </div>
                }
            </div>
        </div>
    }

    @* ── Regression detection ──────────────────────────────────────────────── *@
    @if (_regressionIds.Count > 0)
    {
        <div class="section-card" style="margin-bottom:20px;border-left:4px solid var(--warning)">
            <h2 class="section-title mb-2">
                <i class="bi bi-exclamation-triangle me-2" style="color:var(--warning)"></i>@_regressionIds.Count Regression@(_regressionIds.Count == 1 ? "" : "s") Detected
            </h2>
            <p style="font-size:13px;color:var(--text-secondary);margin-bottom:10px">These cases passed in the previous run but failed this time.</p>
            <div class="d-flex flex-wrap gap-2">
                @foreach (var rn in _regressionNames)
                {
                    <span class="badge badge-fail"><i class="bi bi-arrow-down-circle me-1"></i>@rn</span>
                }
            </div>
        </div>
    }

    <!-- Results table -->
    <div class="section-card">
        <div class="section-header">
            <h2 class="section-title">Results (@_results.Count)</h2>
        </div>
        <table class="data-table">
            <thead>
                <tr>
                    <th>Test Case</th>
                    <th style="text-align:center">Verdict</th>
                    <th style="text-align:center">Overall</th>
                    <th style="text-align:center">Task</th>
                    <th style="text-align:center">Intent</th>
                    <th style="text-align:center">Factual</th>
                    <th style="text-align:center">Helpful</th>
                    <th style="text-align:center">Safety</th>
                    <th style="text-align:center">Latency</th>
                    <th style="text-align:center">Human</th>
                    <th style="text-align:center"></th>
                </tr>
            </thead>
            <tbody>
                @foreach (var r in _results)
                {
                    var isExpanded = _expandedResultId == r.Id;
                    var isRegression = _regressionIds.Contains(r.TestCaseId);
                    <tr style="@(isRegression ? "background:rgba(245,158,11,0.06)" : "")">
                        <td>@r.TestCase?.Name</td>
                        <td style="text-align:center"><span class="badge badge-@r.Verdict">@r.Verdict</span></td>
                        <td style="text-align:center;font-weight:600">@r.OverallScore.ToString("F2")</td>
                        <td style="text-align:center">@r.TaskSuccessScore.ToString("F2")</td>
                        <td style="text-align:center">@r.IntentMatchScore.ToString("F2")</td>
                        <td style="text-align:center">@r.FactualityScore.ToString("F2")</td>
                        <td style="text-align:center">@r.HelpfulnessScore.ToString("F2")</td>
                        <td style="text-align:center">@r.SafetyScore.ToString("F2")</td>
                        <td style="text-align:center;color:var(--text-secondary)">@r.LatencyMs ms</td>
                        <td style="text-align:center">
                            @if (r.HumanVerdict is not null)
                            {
                                <span class="badge badge-@r.HumanVerdict">@r.HumanVerdict</span>
                            }
                            else
                            {
                                <span class="text-muted">—</span>
                            }
                        </td>
                        <td style="text-align:center">
                            <button class="btn btn-sm btn-secondary" @onclick="() => ToggleExpand(r)">@(isExpanded ? "▲" : "▼")</button>
                            <button class="btn btn-sm btn-secondary" @onclick="() => ShowTranscript(r)">Transcript</button>
                            <button class="btn btn-sm btn-secondary" @onclick="() => OpenVerdict(r)">Review</button>
                        </td>
                    </tr>
                    @if (isExpanded)
                    {
                        <tr style="background:var(--light-bg);border-bottom:1px solid var(--border)">
                            <td colspan="11" style="padding:16px 20px">
                                <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(220px,1fr));gap:12px;margin-bottom:14px">
                                    @if (r.TestCase?.UserInput?.Length > 0)
                                    {
                                        <div style="background:white;padding:12px;border-radius:6px;border-left:3px solid var(--primary)">
                                            <div style="font-size:11px;font-weight:600;color:var(--text-secondary);text-transform:uppercase;letter-spacing:0.4px;margin-bottom:4px">User Input</div>
                                            <div style="font-size:13px;color:var(--text-primary);line-height:1.5">@string.Join(" → ", r.TestCase.UserInput.Take(3))@(r.TestCase.UserInput.Length > 3 ? "…" : "")</div>
                                        </div>
                                    }
                                    @if (!string.IsNullOrWhiteSpace(r.TestCase?.ReferenceAnswer) || !string.IsNullOrWhiteSpace(r.TestCase?.AcceptanceCriteria))
                                    {
                                        var _exp = r.TestCase?.ReferenceAnswer ?? r.TestCase?.AcceptanceCriteria ?? "";
                                        <div style="background:white;padding:12px;border-radius:6px;border-left:3px solid var(--success)">
                                            <div style="font-size:11px;font-weight:600;color:var(--text-secondary);text-transform:uppercase;letter-spacing:0.4px;margin-bottom:4px">Expected</div>
                                            <div style="font-size:13px;color:var(--text-primary);line-height:1.5">@(_exp.Length > 250 ? _exp[..248] + "…" : _exp)</div>
                                        </div>
                                    }
                                    @if (!string.IsNullOrWhiteSpace(r.Rationale))
                                    {
                                        <div style="background:white;padding:12px;border-radius:6px;border-left:3px solid var(--warning)">
                                            <div style="font-size:11px;font-weight:600;color:var(--text-secondary);text-transform:uppercase;letter-spacing:0.4px;margin-bottom:4px">Judge Rationale</div>
                                            <div style="font-size:13px;color:var(--text-primary);line-height:1.5">@r.Rationale</div>
                                        </div>
                                    }
                                </div>
                                @* Dimension score bars *@
                                <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(200px,1fr));gap:10px;margin-bottom:12px">
                                    @foreach (var (lbl, sc) in new[] { ("Task Success", r.TaskSuccessScore), ("Intent Match", r.IntentMatchScore), ("Factuality", r.FactualityScore), ("Helpfulness", r.HelpfulnessScore), ("Safety", r.SafetyScore) })
                                    {
                                        var _bc = sc >= 0.8 ? "var(--success)" : sc >= 0.5 ? "var(--warning)" : "var(--danger)";
                                        <div>
                                            <div style="display:flex;justify-content:space-between;font-size:12px;margin-bottom:3px">
                                                <span style="color:var(--text-secondary)">@lbl</span>
                                                <strong style="color:@_bc">@sc.ToString("P0")</strong>
                                            </div>
                                            <div style="background:var(--border);border-radius:3px;height:6px;overflow:hidden">
                                                <div style="height:100%;border-radius:3px;background:@_bc;width:@((sc * 100).ToString("F1"))%"></div>
                                            </div>
                                        </div>
                                    }
                                </div>
                                @* Score history dots *@
                                @if (_scoreHistory.TryGetValue(r.TestCaseId, out var _hist) && _hist.Count >= 2)
                                {
                                    var _delta = _hist.Last() - _hist.First();
                                    <div style="font-size:12px;color:var(--text-secondary);display:flex;align-items:center;gap:8px;flex-wrap:wrap;padding:8px 12px;background:white;border-radius:6px;border-left:3px solid #8b5cf6">
                                        <span style="font-weight:600;color:#6d28d9">Score history (@_hist.Count runs):</span>
                                        <div style="display:flex;gap:3px;align-items:center">
                                            @foreach (var _s in _hist)
                                            {
                                                var _dc = _s >= 80 ? "#10b981" : _s >= 60 ? "#f59e0b" : "#ef4444";
                                                <span title="@_s.ToString("F0")%" style="display:inline-block;width:11px;height:11px;border-radius:50%;background:@_dc"></span>
                                            }
                                        </div>
                                        <span>@_hist.First().ToString("F0")% → @_hist.Last().ToString("F0")%
                                            <strong style="color:@(_delta > 0 ? "#10b981" : _delta < 0 ? "#ef4444" : "#888");margin-left:4px">@(_delta > 0 ? "↑" : _delta < 0 ? "↓" : "→")@Math.Abs(_delta).ToString("F0")pp</strong>
                                        </span>
                                    </div>
                                }
                            </td>
                        </tr>
                    }
                }
                @if (!_results.Any())
                {
                    <tr><td colspan="11" class="empty-row">No results yet.</td></tr>
                }
            </tbody>
        </table>
    </div>

    </div>
}

@* ── Transcript in-page view ─────────────────────────────────────────────── *@
    else if (_transcriptResult is not null)
    {
    <div class="mate-page">
        <div class="section-card">
            <div class="section-header" style="margin-bottom:16px">
                <h2 class="section-title"><i class="bi bi-chat-left-text me-2"></i>Transcript — @_transcriptResult.TestCase?.Name</h2>
                <button class="btn btn-secondary btn-sm" @onclick="() => _transcriptResult = null">
                    <i class="bi bi-arrow-left me-1"></i>Back to Report
                </button>
            </div>
            <div class="row g-3 mb-4">
                <div class="col-md-3">
                    <div class="form-group">
                        <label class="form-label">Test Case</label>
                        <div class="fw-600">@_transcriptResult.TestCase?.Name</div>
                    </div>
                </div>
                <div class="col-md-3">
                    <div class="form-group">
                        <label class="form-label">Verdict</label>
                        <div><span class="badge badge-@_transcriptResult.Verdict">@_transcriptResult.Verdict</span></div>
                    </div>
                </div>
                <div class="col-md-3">
                    <div class="form-group">
                        <label class="form-label">Overall Score</label>
                        <div class="fw-600">@_transcriptResult.OverallScore.ToString("P0")</div>
                    </div>
                </div>
                <div class="col-md-3">
                    <div class="form-group">
                        <label class="form-label">Latency</label>
                        <div class="fw-600">@_transcriptResult.LatencyMs ms</div>
                    </div>
                </div>
            </div>
            <div class="transcript">
                @foreach (var msg in _transcript)
                {
                    <div class="transcript-bubble @msg.Role">
                        <div class="transcript-role">@msg.Role.ToUpper()</div>
                        @if (msg.Role == "bot")
                        {
                            var citations = ExtractCitations(msg.Content);
                            <div class="transcript-content markdown-body">@RenderMarkdown(msg.Content)</div>
                            @if (citations.Count > 0)
                            {
                                <div class="transcript-sources">
                                    <span class="sources-label">Sources</span>
                                    @foreach (var c in citations)
                                    {
                                        var chipText = string.IsNullOrEmpty(c.Label) ? $"[{c.Num}]" : $"[{c.Num}] {c.Label}";
                                        @if (c.Url is not null)
                                        {
                                            <a class="source-chip" href="@c.Url" target="_blank" rel="noopener noreferrer" title="@c.Url">@chipText</a>
                                        }
                                        else
                                        {
                                            <span class="source-chip" title="@c.Label">@chipText</span>
                                        }
                                    }
                                </div>
                            }
                        }
                        else
                        {
                            <div class="transcript-content">@msg.Content</div>
                        }
                        @if (msg.LatencyMs > 0)
                        {
                            <div style="font-size:11px;color:var(--text-secondary);margin-top:4px">@msg.LatencyMs ms</div>
                        }
                    </div>
                }
                @if (!_transcript.Any())
                {
                    <p class="empty-row">No transcript messages recorded.</p>
                }
            </div>
            @if (!string.IsNullOrWhiteSpace(_transcriptResult.Rationale))
            {
                <div class="rationale-box mt-3">
                    <strong>AI Rationale:</strong> @_transcriptResult.Rationale
                </div>
            }
            @if (_transcriptResult.Citations is { Length: > 0 })
            {
                <div class="rationale-box mt-2">
                    <strong>Citations:</strong>
                    <ul style="margin:6px 0 0;padding-left:20px;font-size:13px;line-height:1.6">
                        @foreach (var c in _transcriptResult.Citations)
                        {
                            <li>@c</li>
                        }
                    </ul>
                </div>
            }
            <div class="d-flex gap-2 mt-4">
                <button class="btn btn-secondary" @onclick="() => _transcriptResult = null">
                    <i class="bi bi-arrow-left me-1"></i>Back to Report
                </button>
            </div>
        </div>
    </div>
    }
@* ── Human review in-page view ────────────────────────────────────────────── *@
    else if (_verdictResult is not null)
    {
    <div class="mate-page">
        <div class="section-card">
            <div class="section-header" style="margin-bottom:20px">
                <h2 class="section-title"><i class="bi bi-person-check me-2"></i>Human Review — @_verdictResult.TestCase?.Name</h2>
                <button class="btn btn-secondary btn-sm" @onclick="CloseVerdict">
                    <i class="bi bi-arrow-left me-1"></i>Back to Report
                </button>
            </div>
            <div class="row g-3" style="margin-bottom:16px">
                <div class="col-md-4">
                    <div class="form-group">
                        <label class="form-label">Test Case</label>
                        <div class="fw-600">@_verdictResult.TestCase?.Name</div>
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="form-group">
                        <label class="form-label">AI Verdict</label>
                        <div><span class="badge badge-@_verdictResult.Verdict">@_verdictResult.Verdict</span></div>
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="form-group">
                        <label class="form-label">Overall Score</label>
                        <div class="fw-600">@_verdictResult.OverallScore.ToString("P0")</div>
                    </div>
                </div>
            </div>
            @if (!string.IsNullOrWhiteSpace(_verdictResult.Rationale))
            {
                <div class="rationale-box mb-4"><strong>AI Rationale:</strong> @_verdictResult.Rationale</div>
            }
            <div class="row g-3">
                <div class="col-md-4">
                    <div class="form-group">
                        <label class="form-label">Human Verdict *</label>
                        <select class="form-control" @bind="_verdictValue">
                            <option value="">— select —</option>
                            <option value="pass">Pass</option>
                            <option value="fail">Fail</option>
                        </select>
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="form-group">
                        <label class="form-label">Reviewer Name</label>
                        <input class="form-control" @bind="_verdictBy" placeholder="Your name" />
                    </div>
                </div>
                <div class="col-md-12">
                    <div class="form-group">
                        <label class="form-label">Note</label>
                        <textarea class="form-control" rows="3" @bind="_verdictNote" placeholder="Optional reviewer note"></textarea>
                    </div>
                </div>
            </div>
            @if (!string.IsNullOrWhiteSpace(_verdictError))
            {
                <div class="alert alert-danger mt-3">@_verdictError</div>
            }
            <div class="d-flex gap-2 mt-4">
                <button class="btn btn-primary" @onclick="SaveVerdict">
                    <i class="bi bi-check-lg me-1"></i>Save Review
                </button>
                <button class="btn btn-secondary" @onclick="CloseVerdict">
                    <i class="bi bi-x-lg me-1"></i>Cancel
                </button>
            </div>
        </div>
    </div>
    }
}

@code {
    [Parameter] public Guid RunId { get; set; }

    private bool _loading = true;
    private Run? _run;
    private List<Result> _results = [];

    private Result? _transcriptResult;
    private List<TranscriptMessage> _transcript = [];

    private Result? _verdictResult;
    private string _verdictValue = string.Empty;
    private string _verdictNote = string.Empty;
    private string _verdictBy = string.Empty;
    private string _verdictError = string.Empty;

    // Detail expand
    private Guid? _expandedResultId;

    // Regression detection
    private HashSet<Guid> _regressionIds = [];
    private List<string> _regressionNames = [];

    // Score history per test case (last 6 completed runs)
    private Dictionary<Guid, List<double>> _scoreHistory = [];

    // Auto-poll
    private bool _disposed;

    private static readonly MarkdownPipeline _mdPipeline =
        new MarkdownPipelineBuilder().UseAdvancedExtensions().Build();

    private static readonly System.Text.RegularExpressions.Regex _citationLineRegex =
        new(@"^\[(\d+)\]: cite:(\S+)(?:\s+""([^""]*)"")?", System.Text.RegularExpressions.RegexOptions.Multiline | System.Text.RegularExpressions.RegexOptions.Compiled);

    private record CitationEntry(int Num, string? Url, string Label);

    private static List<CitationEntry> ExtractCitations(string? text)
    {
        if (string.IsNullOrWhiteSpace(text)) return [];
        var result = new List<CitationEntry>();
        foreach (System.Text.RegularExpressions.Match m in _citationLineRegex.Matches(text))
        {
            var num   = int.Parse(m.Groups[1].Value);
            var citeRef = m.Groups[2].Value;                        // e.g. "1" or "https://..."
            var title   = m.Groups[3].Success ? m.Groups[3].Value : null;

            string? url = null;
            string label;

            if (citeRef.StartsWith("http://", StringComparison.OrdinalIgnoreCase) ||
                citeRef.StartsWith("https://", StringComparison.OrdinalIgnoreCase))
            {
                url = citeRef;
                if (!string.IsNullOrWhiteSpace(title) && !IsGenericTitle(title, num))
                    label = title;
                else
                {
                    // Use filename from path, fallback to hostname
                    var uri = new Uri(citeRef);
                    var seg = System.IO.Path.GetFileName(uri.AbsolutePath.TrimEnd('/'));
                    label = string.IsNullOrWhiteSpace(seg) ? uri.Host : Uri.UnescapeDataString(seg);
                }
            }
            else
            {
                // Numeric reference — use title if descriptive, otherwise just [N]
                label = (!string.IsNullOrWhiteSpace(title) && !IsGenericTitle(title, num))
                    ? title
                    : string.Empty;
            }

            result.Add(new CitationEntry(num, url, label));
        }
        return result;
    }

    private static bool IsGenericTitle(string title, int num) =>
        string.Equals(title, $"Citation-{num}", StringComparison.OrdinalIgnoreCase) ||
        string.Equals(title, $"Source {num}", StringComparison.OrdinalIgnoreCase);

    private static MarkupString RenderMarkdown(string? text)
    {
        if (string.IsNullOrWhiteSpace(text)) return new MarkupString(string.Empty);
        // Strip Copilot Studio citation reference lines: [1]: cite:1 "Title"
        var cleaned = _citationLineRegex.Replace(text, string.Empty);
        var html = Markdown.ToHtml(cleaned.Trim(), _mdPipeline);
        return new MarkupString(html);
    }

    protected override async Task OnInitializedAsync()
    {
        _run = await Db.Runs
            .Include(r => r.Suite)
            .Include(r => r.Agent)
            .FirstOrDefaultAsync(r => r.Id == RunId);

        if (_run is not null)
        {
            _results = await Db.Results
                .Include(r => r.TestCase)
                .Where(r => r.RunId == RunId)
                .ToListAsync();

            await LoadRegressionDataAsync();
            await LoadScoreHistoryAsync();
        }
        _loading = false;
    }

    protected override Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender && _run?.Status is "pending" or "running")
            _ = PollAsync();
        return Task.CompletedTask;
    }

    private async Task PollAsync()
    {
        try
        {
            while (!_disposed)
            {
                await Task.Delay(3000);
                if (_disposed) break;

                await InvokeAsync(async () =>
                {
                    var updated = await Db.Runs
                        .AsNoTracking()
                        .Include(r => r.Suite)
                        .Include(r => r.Agent)
                        .FirstOrDefaultAsync(r => r.Id == RunId);
                    if (updated is not null) _run = updated;

                    _results = await Db.Results
                        .AsNoTracking()
                        .Include(r => r.TestCase)
                        .Where(r => r.RunId == RunId)
                        .ToListAsync();

                    StateHasChanged();
                });

                if (_run?.Status is not ("pending" or "running")) break;
            }

            // Final enrichment once run is done
            if (!_disposed && _run?.Status is "completed" or "failed")
            {
                await InvokeAsync(async () =>
                {
                    await LoadRegressionDataAsync();
                    await LoadScoreHistoryAsync();
                    StateHasChanged();
                });
            }
        }
        catch (Exception) { /* circuit disposed — swallow */ }
    }

    private async Task LoadRegressionDataAsync()
    {
        if (_run is null) return;

        var prevRun = await Db.Runs
            .Where(r => r.SuiteId == _run.SuiteId && r.Status == "completed" && r.Id != RunId)
            .OrderByDescending(r => r.StartedAt)
            .Select(r => r.Id)
            .FirstOrDefaultAsync();

        if (prevRun == default) return;

        var prevPassedIds = await Db.Results
            .Where(r => r.RunId == prevRun &&
                        (r.HumanVerdict == "pass" || (r.HumanVerdict == null && r.Verdict == "pass")))
            .Select(r => r.TestCaseId)
            .ToListAsync();

        var prevPassedSet = prevPassedIds.ToHashSet();

        var failed = _results
            .Where(r => (r.HumanVerdict ?? r.Verdict) == "fail" && prevPassedSet.Contains(r.TestCaseId))
            .ToList();

        _regressionIds = failed.Select(r => r.TestCaseId).ToHashSet();
        _regressionNames = failed.Select(r => r.TestCase?.Name ?? r.TestCaseId.ToString()).ToList();
    }

    private async Task LoadScoreHistoryAsync()
    {
        if (!_results.Any()) return;

        var tcIds = _results.Select(r => r.TestCaseId).Distinct().ToList();

        var scoreRows = await Db.Results
            .AsNoTracking()
            .Where(r => tcIds.Contains(r.TestCaseId) && r.Run!.Status == "completed")
            .OrderBy(r => r.EvaluatedAt)
            .Select(r => new { r.TestCaseId, Score = r.OverallScore * 100, r.EvaluatedAt })
            .ToListAsync();

        _scoreHistory = scoreRows
            .GroupBy(r => r.TestCaseId)
            .ToDictionary(
                g => g.Key,
                g => g.OrderBy(r => r.EvaluatedAt).Select(r => r.Score).TakeLast(6).ToList());
    }

    private void ToggleExpand(Result r)
    {
        _expandedResultId = _expandedResultId == r.Id ? null : r.Id;
    }

    private async Task ShowTranscript(Result r)
    {
        _transcriptResult = r;
        _transcript = await Db.TranscriptMessages
            .Where(m => m.ResultId == r.Id)
            .OrderBy(m => m.TurnIndex)
            .ToListAsync();
    }

    private void OpenVerdict(Result r)
    {
        _verdictResult = r;
        _verdictValue = r.HumanVerdict ?? string.Empty;
        _verdictNote = r.HumanVerdictNote ?? string.Empty;
        _verdictBy = r.HumanVerdictBy ?? string.Empty;
        _verdictError = string.Empty;
    }

    private void CloseVerdict()
    {
        _verdictResult = null;
        _verdictError = string.Empty;
    }

    private async Task SaveVerdict()
    {
        if (_verdictResult is null) return;
        if (_verdictValue is not ("pass" or "fail"))
        {
            _verdictError = "Please select pass or fail.";
            return;
        }
        var result = await Db.Results.FindAsync(_verdictResult.Id);
        if (result is null) return;
        result.HumanVerdict = _verdictValue;
        result.HumanVerdictNote = _verdictNote;
        result.HumanVerdictAt = DateTime.UtcNow;
        result.HumanVerdictBy = string.IsNullOrWhiteSpace(_verdictBy) ? "reviewer" : _verdictBy;
        await Db.SaveChangesAsync();
        var idx = _results.FindIndex(r => r.Id == result.Id);
        if (idx >= 0) _results[idx] = result;
        CloseVerdict();
    }

    private async Task ExportCsv()
    {
        var sb = new StringBuilder();
        sb.AppendLine("TestCase,Verdict,OverallScore,TaskSuccess,IntentMatch,Factuality,Helpfulness,Safety,LatencyMs,HumanVerdict,HumanVerdictNote");
        foreach (var r in _results)
        {
            var name = r.TestCase?.Name?.Replace(",", ";") ?? "";
            sb.AppendLine($"{name},{r.Verdict},{r.OverallScore:F4},{r.TaskSuccessScore:F4},{r.IntentMatchScore:F4},{r.FactualityScore:F4},{r.HelpfulnessScore:F4},{r.SafetyScore:F4},{r.LatencyMs},{r.HumanVerdict ?? ""},{r.HumanVerdictNote?.Replace(",", ";") ?? ""}");
        }
        var bytes = Encoding.UTF8.GetBytes(sb.ToString());
        var base64 = Convert.ToBase64String(bytes);
        await JS.InvokeVoidAsync("downloadCsvFromBase64", base64, $"run-{RunId:N}.csv");
    }

    public void Dispose() => _disposed = true;
}
