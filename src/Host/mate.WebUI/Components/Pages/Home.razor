@page "/"
@using mate.Data
@using mate.Domain.Entities
@using Microsoft.EntityFrameworkCore
@inject mateDbContext Db
@inject NavigationManager Navigation

<PageTitle>Home — @BrandInfo.BrandName</PageTitle>

<div class="mate-header">
    <h1>Welcome to @BrandInfo.BrandName</h1>
    <p>@BrandInfo.BrandTagline</p>
</div>
<div class="mate-page">

@if (_loading)
{
    <div class="d-flex align-items-center gap-2 py-4"><span class="spinner"></span><span>Loading…</span></div>
}
else
{
    <!-- Quick-start actions -->
    <div class="row g-3 mb-4">
        <div class="col-md-4">
            <div class="section-card h-100" style="cursor:pointer" @onclick='() => Navigation.NavigateTo("/wizard")'>
                <div class="d-flex align-items-center gap-3 mb-3">
                    <div style="width:48px;height:48px;background:linear-gradient(135deg,#0066cc,#8b5cf6);border-radius:12px;display:flex;align-items:center;justify-content:center;color:white">
                        <i class="bi bi-magic fs-5"></i>
                    </div>
                    <div>
                        <div class="fw-600">Setup Wizard</div>
                        <div class="text-muted" style="font-size:12px">Onboard tenants &amp; agents</div>
                    </div>
                </div>
                <p class="text-muted mb-0" style="font-size:13px">New here? Use the wizard to configure tenants, add agents, and create your first test suite in minutes.</p>
            </div>
        </div>
        <div class="col-md-4">
            <div class="section-card h-100" style="cursor:pointer" @onclick='() => Navigation.NavigateTo("/test-suites")'>
                <div class="d-flex align-items-center gap-3 mb-3">
                    <div style="width:48px;height:48px;background:linear-gradient(135deg,#10b981,#06b6d4);border-radius:12px;display:flex;align-items:center;justify-content:center;color:white">
                        <i class="bi bi-list-check fs-5"></i>
                    </div>
                    <div>
                        <div class="fw-600">Test Suites</div>
                        <div class="text-muted" style="font-size:12px">Manage &amp; run test cases</div>
                    </div>
                </div>
                <p class="text-muted mb-0" style="font-size:13px">Create test suites, define test cases, and run evaluations against your registered agents.</p>
            </div>
        </div>
        <div class="col-md-4">
            <div class="section-card h-100" style="cursor:pointer" @onclick='() => Navigation.NavigateTo("/dashboard")'>
                <div class="d-flex align-items-center gap-3 mb-3">
                    <div style="width:48px;height:48px;background:linear-gradient(135deg,#f59e0b,#ef4444);border-radius:12px;display:flex;align-items:center;justify-content:center;color:white">
                        <i class="bi bi-graph-up fs-5"></i>
                    </div>
                    <div>
                        <div class="fw-600">Dashboard</div>
                        <div class="text-muted" style="font-size:12px">KPIs &amp; run history</div>
                    </div>
                </div>
                <p class="text-muted mb-0" style="font-size:13px">View pass rates, latency trends, and a full history of test runs across all agents.</p>
            </div>
        </div>
    </div>

    <!-- Platform health + stats -->
    <div class="row g-3 mb-4">
        <div class="col-md-6">
            <div class="section-card">
                <h2 class="section-title mb-3">Platform Status</h2>
                <div class="d-flex flex-column gap-2">
                    <div class="d-flex justify-content-between align-items-center">
                        <span><span class="health-dot healthy"></span>Database</span>
                        <span class="badge badge-pass">Healthy</span>
                    </div>
                    <div class="d-flex justify-content-between align-items-center">
                        <span><span class="health-dot @(_agentCount > 0 ? "healthy" : "unknown")"></span>Agents registered</span>
                        <span class="badge badge-info">@_agentCount active</span>
                    </div>
                    <div class="d-flex justify-content-between align-items-center">
                        <span><span class="health-dot @(_suiteCount > 0 ? "healthy" : "unknown")"></span>Test suites</span>
                        <span class="badge badge-info">@_suiteCount configured</span>
                    </div>
                </div>
                <div class="mt-3">
                    <a href="/health/ready" target="_blank" class="btn btn-sm btn-secondary">
                        <i class="bi bi-activity"></i> Full health report
                    </a>
                </div>
            </div>
        </div>
        <div class="col-md-6">
            <div class="section-card">
                <h2 class="section-title mb-3">Recent Activity</h2>
                @if (_recentRuns.Count == 0)
                {
                    <div class="empty-state py-2">
                        <p>No runs yet. <a href="/wizard">Get started →</a></p>
                    </div>
                }
                else
                {
                    <div class="d-flex flex-column gap-2">
                        @foreach (var run in _recentRuns.Take(5))
                        {
                            <div class="d-flex justify-content-between align-items-center">
                                <div>
                                    <div style="font-size:13px;font-weight:500">@(run.Suite?.Name ?? "—")</div>
                                    <div style="font-size:11px;color:var(--text-secondary)">@run.StartedAt.ToString("MMM d, HH:mm")</div>
                                </div>
                                <div class="d-flex align-items-center gap-2">
                                    <span class="badge badge-@run.Status">@run.Status</span>
                                    <a href="/runs/@run.Id" class="btn btn-sm btn-secondary">→</a>
                                </div>
                            </div>
                        }
                    </div>
                }
            </div>
        </div>
    </div>

    <!-- Quick links -->
    <div class="section-card">
        <h2 class="section-title mb-3">Quick Links</h2>
        <div class="d-flex gap-3 flex-wrap">
            <a href="/agents"          class="btn btn-secondary"><i class="bi bi-robot"></i> Agents</a>
            <a href="/rubrics"         class="btn btn-secondary"><i class="bi bi-award"></i> Rubrics</a>
            <a href="/documents"       class="btn btn-secondary"><i class="bi bi-file-earmark"></i> Documents</a>
            <a href="/discover"        class="btn btn-secondary"><i class="bi bi-compass"></i> Discover</a>
            <a href="/settings"        class="btn btn-secondary"><i class="bi bi-gear"></i> Settings</a>
            <a href="/scalar/v1" target="_blank" class="btn btn-secondary"><i class="bi bi-code-slash"></i> API Reference ↗</a>
        </div>
    </div>
}
</div>

@code {
    private bool _loading = true;
    private int _agentCount;
    private int _suiteCount;
    private List<Run> _recentRuns = [];

    protected override async Task OnInitializedAsync()
    {
        _agentCount = await Db.Agents.CountAsync(a => a.IsActive);
        _suiteCount = await Db.TestSuites.CountAsync();
        _recentRuns = await Db.Runs
            .Include(r => r.Suite)
            .OrderByDescending(r => r.StartedAt)
            .Take(5)
            .ToListAsync();
        _loading = false;
    }
}
