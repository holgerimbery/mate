@attribute [Authorize]
@page "/help"
@using Microsoft.EntityFrameworkCore
@using System.Diagnostics
@using Microsoft.AspNetCore.Hosting
@using Microsoft.Extensions.Configuration
@inject IConfiguration Configuration
@inject IWebHostEnvironment HostEnv
@inject IHttpClientFactory HttpClientFactory
@inject NavigationManager NavigationManager
@inject mateDbContext Db

<PageTitle>Help — @BrandInfo.BrandName</PageTitle>

<div class="mate-header">
    <h1>Help &amp; Documentation</h1>
    <p>Source, author info, runtime environment and API reference for @BrandInfo.BrandName
        @if (!string.IsNullOrEmpty(_appVersion))
        {
            <span class="badge ms-2" style="background:var(--primary);color:#fff;font-size:11px;font-weight:600;padding:2px 10px;border-radius:10px;vertical-align:middle">@_appVersion</span>
        }
    </p>

<div class="row g-4">

    <!-- Source & Documentation -->
    <div class="col-md-4">
        <div class="section-card h-100 d-flex flex-column">
            <div class="icon-tile-lg icon-tile-github">
                <i class="bi bi-github" style="font-size:24px"></i>
            </div>
            <h2 class="section-title">Source &amp; Documentation</h2>
            <p class="text-muted" style="font-size:13px;flex:1">Access the source code and comprehensive documentation for @BrandInfo.BrandName.</p>
            <div class="d-flex flex-column gap-2 mt-2">
                <a href="https://github.com/HolgerImbery/mate" target="_blank" class="btn btn-secondary btn-sm"><i class="bi bi-code-square me-1"></i>View Source Code</a>
                <a href="https://github.com/HolgerImbery/mate/wiki" target="_blank" class="btn btn-secondary btn-sm"><i class="bi bi-book me-1"></i>Read Documentation</a>
                <a href="https://github.com/HolgerImbery/mate/wiki/Developer-Changelog" target="_blank" class="btn btn-secondary btn-sm"><i class="bi bi-clock-history me-1"></i>View Changelog</a>
            </div>
        </div>
    </div>

    <!-- About the Author -->
    <div class="col-md-4">
        <div class="section-card h-100 d-flex flex-column">
            <div class="icon-tile-lg icon-tile-primary">
                <i class="bi bi-person-circle" style="font-size:24px"></i>
            </div>
            <h2 class="section-title">About the Author</h2>
            <p class="text-muted" style="font-size:13px;flex:1">Created by Holger Imbery. Connect on GitHub or LinkedIn to learn more.</p>
            <div class="d-flex flex-column gap-2 mt-2">
                <a href="https://github.com/holgerimbery" target="_blank" class="btn btn-secondary btn-sm"><i class="bi bi-github me-1"></i>GitHub Profile</a>
                <a href="https://www.linkedin.com/in/holgerimbery/" target="_blank" class="btn btn-secondary btn-sm"><i class="bi bi-linkedin me-1"></i>LinkedIn Profile</a>
            </div>
        </div>
    </div>

    <!-- Runtime Environment -->
    <div class="col-md-4">
        <div class="section-card h-100">
            <div class="icon-tile-lg icon-tile-neutral-dark">
                <i class="bi bi-server" style="font-size:24px"></i>
            </div>
            <h2 class="section-title">Runtime Environment</h2>
            <div class="d-flex flex-column gap-2" style="font-size:13px">
                @if (!string.IsNullOrEmpty(_appVersion))
                {
                    <div class="d-flex justify-content-between align-items-center pb-2 border-bottom">
                        <span class="text-muted"><i class="bi bi-tag me-1"></i>Version</span>
                        <span class="badge badge-info">@_appVersion</span>
                    </div>
                }
                <div class="d-flex justify-content-between align-items-center pb-2 border-bottom">
                    <span class="text-muted"><i class="bi bi-box me-1"></i>Hosting</span>
                    @if (_inContainer)
                    {
                        <span class="badge badge-info"><i class="bi bi-box-seam me-1"></i>Container</span>
                    }
                    else
                    {
                        <span class="badge badge-pass"><i class="bi bi-hdd me-1"></i>Bare Metal</span>
                    }
                </div>
                <div class="d-flex justify-content-between align-items-center pb-2 border-bottom">
                    <span class="text-muted"><i class="bi bi-database me-1"></i>Database Mode</span>
                    @if (string.Equals(_databaseMode, "PostgreSQL", StringComparison.OrdinalIgnoreCase))
                    {
                        <span class="badge badge-pass"><i class="bi bi-server me-1"></i>PostgreSQL</span>
                    }
                    else if (string.Equals(_databaseMode, "SQLite", StringComparison.OrdinalIgnoreCase))
                    {
                        <span class="badge badge-info"><i class="bi bi-hdd-stack me-1"></i>SQLite</span>
                    }
                    else
                    {
                        <span class="badge badge-neutral">@_databaseMode</span>
                    }
                </div>
                <div class="d-flex justify-content-between align-items-center pb-2 border-bottom">
                    <span class="text-muted"><i class="bi bi-key me-1"></i>Secrets Mode</span>
                    @if (_keyVaultMode)
                    {
                        <span class="badge badge-pass"><i class="bi bi-shield-lock me-1"></i>Key Vault</span>
                    }
                    else
                    {
                        <span class="badge badge-info"><i class="bi bi-database me-1"></i>Database</span>
                    }
                </div>
                <div class="d-flex justify-content-between align-items-center pb-2 border-bottom">
                    <span class="text-muted"><i class="bi bi-shield-lock me-1"></i>Authentication</span>
                    @if (_authEnabled)
                    {
                        <span class="badge badge-pass"><i class="bi bi-check-circle me-1"></i>Entra ID</span>
                    }
                    else if (string.Equals(_authScheme, "Generic", StringComparison.OrdinalIgnoreCase))
                    {
                        <span class="badge badge-pending"><i class="bi bi-exclamation-triangle me-1"></i>Development Mode</span>
                    }
                    else
                    {
                        <span class="badge badge-neutral"><i class="bi bi-x-circle me-1"></i>Disabled</span>
                    }
                </div>
                <div class="d-flex justify-content-between align-items-center pb-2 border-bottom">
                    <span class="text-muted"><i class="bi bi-building-gear me-1"></i>Enterprise</span>
                    @if (_redmondMode)
                    {
                        <span class="badge badge-pass">True</span>
                    }
                    else
                    {
                        <span class="badge badge-neutral">False</span>
                    }
                </div>
                @if (_redmondMode)
                {
                    <div class="d-flex justify-content-between align-items-center pb-2 border-bottom">
                        <span class="text-muted"><i class="bi bi-diagram-3 me-1"></i>Tenant ID</span>
                        @if (string.IsNullOrWhiteSpace(_tenantIdDisplay))
                        {
                            <span class="badge badge-neutral">Not configured</span>
                        }
                        else
                        {
                            <span class="badge badge-info">@_tenantIdDisplay</span>
                        }
                    </div>
                }
                <div class="d-flex justify-content-between align-items-center pb-2 border-bottom">
                    <span class="text-muted"><i class="bi bi-gear me-1"></i>ASP.NET Env</span>
                    <span class="badge badge-purple">@HostEnv.EnvironmentName</span>
                </div>
                <div class="d-flex justify-content-between align-items-center pb-2 border-bottom">
                    <span class="text-muted"><i class="bi bi-arrow-left-right me-1"></i>Proxy Headers</span>
                    @if (_forwardedHeaders)
                    {
                        <span class="badge badge-pass"><i class="bi bi-check-circle me-1"></i>Enabled</span>
                    }
                    else
                    {
                        <span class="badge badge-neutral">Disabled</span>
                    }
                </div>
                <div class="d-flex justify-content-between align-items-center">
                    <span class="text-muted"><i class="bi bi-braces me-1"></i>API Explorer</span>
                    <div class="d-flex gap-2 align-items-center">
                        <a href="/scalar/v1" target="_blank" style="font-size:12px">Scalar UI ↗</a>
                        <a href="/openapi/v1.json" download="mate-openapi.json" style="font-size:12px">OpenAPI spec ↓</a>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- System Health Check -->
    <div class="col-12">
        <div class="section-card">
            <div class="d-flex align-items-center justify-content-between mb-3 flex-wrap gap-2">
                <h2 class="section-title mb-0"><i class="bi bi-heart-pulse me-2" style="color:var(--primary)"></i>System Health</h2>
                <button class="btn btn-primary btn-sm" @onclick="RunHealthCheck" disabled="@_healthRunning">
                    @if (_healthRunning)
                    {
                        <span class="spinner-border spinner-border-sm me-1" role="status" aria-hidden="true"></span>
                        <span>Checking…</span>
                    }
                    else
                    {
                        <i class="bi bi-play-circle me-1"></i><span>Run Health Check</span>
                    }
                </button>
            </div>
            @if (_healthChecks is not null)
            {
                <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(180px,1fr));gap:12px">
                    @foreach (var check in _healthChecks)
                    {
                        <div class="kpi-card" style="border-left:4px solid @(check.Ok ? "var(--success)" : "var(--danger)");text-align:left;min-height:90px">
                            <div style="font-size:1rem;margin-bottom:4px">
                                @if (check.Ok)
                                {
                                    <i class="bi bi-check-circle-fill" style="color:var(--success)"></i>
                                }
                                else
                                {
                                    <i class="bi bi-x-circle-fill" style="color:var(--danger)"></i>
                                }
                                <strong style="margin-left:6px;font-size:13px">@check.Name</strong>
                            </div>
                            <div style="font-size:11px;color:var(--text-muted)">@check.Detail</div>
                            @if (check.Ms >= 0)
                            {
                                <div style="font-size:11px;color:var(--text-muted)">@check.Ms ms</div>
                            }
                        </div>
                    }
                </div>
            }
            else
            {
                <p class="text-muted mb-0">Click <strong>Run Health Check</strong> to verify database connectivity and key API endpoints.</p>
            }
        </div>
    </div>

</div>
</div>

@code {
    private record HealthCheck(string Name, bool Ok, string Detail, long Ms);
    private bool _healthRunning;
    private List<HealthCheck>? _healthChecks;

    private string _appVersion     = "";
    private bool   _inContainer;
    private bool   _authEnabled;
    private string _authScheme     = "";
    private bool   _redmondMode;
    private string _tenantIdDisplay = "";
    private string _databaseMode   = "Unknown";
    private bool   _forwardedHeaders;
    private bool   _keyVaultMode;

    protected override void OnInitialized()
    {
        var versionFile = Path.Combine(AppContext.BaseDirectory, "VERSION");
        if (File.Exists(versionFile))
            _appVersion = NormalizeVersion(File.ReadAllText(versionFile).Trim());

        _inContainer = string.Equals(
            Environment.GetEnvironmentVariable("DOTNET_RUNNING_IN_CONTAINER"), "true",
            StringComparison.OrdinalIgnoreCase) || File.Exists("/.dockerenv");

        _authScheme  = Configuration["Authentication:Scheme"] ?? "None";
        _authEnabled = string.Equals(_authScheme, "EntraId", StringComparison.OrdinalIgnoreCase);
        _redmondMode = Configuration.GetValue<bool>("RedmondMode", false);
        _tenantIdDisplay = Configuration["AzureContext:TenantId"]
            ?? Configuration["AzureAd:TenantId"]
            ?? Environment.GetEnvironmentVariable("AzureContext__TenantId")
            ?? Environment.GetEnvironmentVariable("AzureAd__TenantId")
            ?? string.Empty;

        var providerName = Db.Database.ProviderName ?? string.Empty;
        _databaseMode = providerName.Contains("Npgsql", StringComparison.OrdinalIgnoreCase)
            ? "PostgreSQL"
            : providerName.Contains("Sqlite", StringComparison.OrdinalIgnoreCase)
                ? "SQLite"
                : (string.IsNullOrWhiteSpace(providerName) ? "Unknown" : providerName);

        _forwardedHeaders = string.Equals(
            Environment.GetEnvironmentVariable("ASPNETCORE_FORWARDEDHEADERS_ENABLED"), "true",
            StringComparison.OrdinalIgnoreCase);

        var useKeyVaultForSecrets = Configuration.GetValue<bool>("AzureInfrastructure:UseKeyVaultForSecrets", false);
        var useMultiVaultForSecrets = Configuration.GetValue<bool>("AzureInfrastructure:UseMultiVaultForSecrets", false);
        var keyVaultUri = Configuration["AzureInfrastructure:KeyVaultUri"];
        var platformVaultUri = Configuration["AzureInfrastructure:PlatformVaultUri"];
        var tenantVaultUriTemplate = Configuration["AzureInfrastructure:TenantVaultUriTemplate"];

        var hasSingleVaultConfig = !string.IsNullOrWhiteSpace(keyVaultUri);
        var hasMultiVaultConfig = useMultiVaultForSecrets &&
                                  !string.IsNullOrWhiteSpace(platformVaultUri) &&
                                  !string.IsNullOrWhiteSpace(tenantVaultUriTemplate);

        _keyVaultMode = useKeyVaultForSecrets && (hasSingleVaultConfig || hasMultiVaultConfig);
    }

    private static string NormalizeVersion(string? version)
    {
        if (string.IsNullOrWhiteSpace(version)) return string.Empty;
        return version.Trim().TrimStart('v', 'V');
    }

    private async Task RunHealthCheck()
    {
        _healthRunning = true;
        _healthChecks  = null;
        StateHasChanged();

        var results = new List<HealthCheck>();
        var sw      = Stopwatch.StartNew();

        // Database connectivity
        try
        {
            sw.Restart();
            var count = await Db.TestSuites.CountAsync();
            results.Add(new("Database", true, $"Reachable — {count} suite(s)", sw.ElapsedMilliseconds));
        }
        catch (Exception ex)
        {
            results.Add(new("Database", false, ex.Message[..Math.Min(60, ex.Message.Length)], -1));
        }

        // Agent count
        try
        {
            sw.Restart();
            var count = await Db.Agents.CountAsync();
            results.Add(new("Agents", true, $"{count} agent(s)", sw.ElapsedMilliseconds));
        }
        catch (Exception ex)
        {
            results.Add(new("Agents", false, ex.Message[..Math.Min(60, ex.Message.Length)], -1));
        }

        // Runs count
        try
        {
            sw.Restart();
            var count = await Db.Runs.CountAsync();
            results.Add(new("Runs", true, $"{count} run(s)", sw.ElapsedMilliseconds));
        }
        catch (Exception ex)
        {
            results.Add(new("Runs", false, ex.Message[..Math.Min(60, ex.Message.Length)], -1));
        }

        // Documents count
        try
        {
            sw.Restart();
            var count = await Db.Documents.CountAsync();
            results.Add(new("Documents", true, $"{count} document(s)", sw.ElapsedMilliseconds));
        }
        catch (Exception ex)
        {
            results.Add(new("Documents", false, ex.Message[..Math.Min(60, ex.Message.Length)], -1));
        }

        // HTTP self-check: /health endpoint
        try
        {
            var baseUri = NavigationManager.BaseUri.TrimEnd('/');
            var client  = HttpClientFactory.CreateClient();
            using var cts = new System.Threading.CancellationTokenSource(TimeSpan.FromSeconds(5));
            sw.Restart();
            var resp = await client.GetAsync(baseUri + "/health", cts.Token);
            var ok   = (int)resp.StatusCode < 500;
            results.Add(new("/health endpoint", ok, $"HTTP {(int)resp.StatusCode}", sw.ElapsedMilliseconds));
        }
        catch (Exception ex)
        {
            results.Add(new("/health endpoint", false, ex.Message[..Math.Min(60, ex.Message.Length)], -1));
        }

        _healthChecks = results;
        _healthRunning = false;
    }
}
