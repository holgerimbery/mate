@attribute [Authorize]
@page "/help"
@using Microsoft.EntityFrameworkCore
@using System.Diagnostics
@using Microsoft.AspNetCore.Hosting
@using Microsoft.Extensions.Configuration
@inject IConfiguration Configuration
@inject IWebHostEnvironment HostEnv
@inject IHttpClientFactory HttpClientFactory
@inject NavigationManager NavigationManager
@inject mateDbContext Db

<PageTitle>Help — @BrandInfo.BrandName</PageTitle>

<div class="mate-header">
    <h1>Help &amp; Documentation</h1>
    <p>Source, author info, runtime environment and API reference for @BrandInfo.BrandName
        @if (!string.IsNullOrEmpty(_appVersion))
        {
            <span class="badge ms-2" style="background:var(--primary,#0066cc);color:#fff;font-size:11px;font-weight:600;padding:2px 10px;border-radius:10px;vertical-align:middle">v@_appVersion</span>
        }
    </p>

<div class="row g-4">

    <!-- Source & Documentation -->
    <div class="col-md-4">
        <div class="section-card h-100 d-flex flex-column">
            <div style="width:48px;height:48px;background:linear-gradient(135deg,#24292e,#1a1e22);border-radius:12px;margin-bottom:16px;display:flex;align-items:center;justify-content:center;color:#fff;flex-shrink:0">
                <i class="bi bi-github" style="font-size:24px"></i>
            </div>
            <h2 class="section-title">Source &amp; Documentation</h2>
            <p class="text-muted" style="font-size:13px;flex:1">Access the source code and comprehensive documentation for @BrandInfo.BrandName.</p>
            <div class="d-flex flex-column gap-2 mt-2">
                <a href="https://github.com/HolgerImbery/mate" target="_blank" class="btn btn-secondary btn-sm"><i class="bi bi-code-square me-1"></i>View Source Code</a>
                <a href="https://github.com/HolgerImbery/mate/wiki" target="_blank" class="btn btn-secondary btn-sm"><i class="bi bi-book me-1"></i>Read Documentation</a>
            </div>
        </div>
    </div>

    <!-- About the Author -->
    <div class="col-md-4">
        <div class="section-card h-100 d-flex flex-column">
            <div style="width:48px;height:48px;background:linear-gradient(135deg,#0066cc,#003d99);border-radius:12px;margin-bottom:16px;display:flex;align-items:center;justify-content:center;color:#fff;flex-shrink:0">
                <i class="bi bi-person-circle" style="font-size:24px"></i>
            </div>
            <h2 class="section-title">About the Author</h2>
            <p class="text-muted" style="font-size:13px;flex:1">Created by Holger Imbery. Connect on GitHub or LinkedIn to learn more.</p>
            <div class="d-flex flex-column gap-2 mt-2">
                <a href="https://github.com/holgerimbery" target="_blank" class="btn btn-secondary btn-sm"><i class="bi bi-github me-1"></i>GitHub Profile</a>
                <a href="https://www.linkedin.com/in/holgerimbery/" target="_blank" class="btn btn-secondary btn-sm"><i class="bi bi-linkedin me-1"></i>LinkedIn Profile</a>
            </div>
        </div>
    </div>

    <!-- Runtime Environment -->
    <div class="col-md-4">
        <div class="section-card h-100">
            <div style="width:48px;height:48px;background:linear-gradient(135deg,#37474f,#1c2529);border-radius:12px;margin-bottom:16px;display:flex;align-items:center;justify-content:center;color:#fff">
                <i class="bi bi-server" style="font-size:24px"></i>
            </div>
            <h2 class="section-title">Runtime Environment</h2>
            <div class="d-flex flex-column gap-2" style="font-size:13px">
                <div class="d-flex justify-content-between align-items-center pb-2 border-bottom">
                    <span class="text-muted"><i class="bi bi-box me-1"></i>Hosting</span>
                    @if (_inContainer)
                    {
                        <span class="badge" style="background:#e3f2fd;color:#1565c0"><i class="bi bi-box-seam me-1"></i>Container</span>
                    }
                    else
                    {
                        <span class="badge" style="background:#e8f5e9;color:#2e7d32"><i class="bi bi-hdd me-1"></i>Bare Metal</span>
                    }
                </div>
                <div class="d-flex justify-content-between align-items-center pb-2 border-bottom">
                    <span class="text-muted"><i class="bi bi-shield-lock me-1"></i>Authentication</span>
                    @if (_authEnabled)
                    {
                        <span class="badge" style="background:#e8f5e9;color:#2e7d32"><i class="bi bi-check-circle me-1"></i>Entra ID</span>
                    }
                    else if (string.Equals(_authScheme, "Generic", StringComparison.OrdinalIgnoreCase))
                    {
                        <span class="badge" style="background:#fff3e0;color:#e65100"><i class="bi bi-exclamation-triangle me-1"></i>Development Mode</span>
                    }
                    else
                    {
                        <span class="badge" style="background:#f5f5f5;color:#757575"><i class="bi bi-x-circle me-1"></i>Disabled</span>
                    }
                </div>
                <div class="d-flex justify-content-between align-items-center pb-2 border-bottom">
                    <span class="text-muted"><i class="bi bi-gear me-1"></i>ASP.NET Env</span>
                    <span class="badge" style="background:#f3e5f5;color:#6a1b9a">@HostEnv.EnvironmentName</span>
                </div>
                <div class="d-flex justify-content-between align-items-center pb-2 border-bottom">
                    <span class="text-muted"><i class="bi bi-arrow-left-right me-1"></i>Proxy Headers</span>
                    @if (_forwardedHeaders)
                    {
                        <span class="badge" style="background:#e8f5e9;color:#2e7d32"><i class="bi bi-check-circle me-1"></i>Enabled</span>
                    }
                    else
                    {
                        <span class="badge" style="background:#f5f5f5;color:#9e9e9e">Disabled</span>
                    }
                </div>
                <div class="d-flex justify-content-between align-items-center">
                    <span class="text-muted"><i class="bi bi-braces me-1"></i>API Explorer</span>
                    <a href="/scalar/v1" target="_blank" style="font-size:12px">Scalar UI ↗</a>
                </div>
            </div>
        </div>
    </div>

    <!-- System Health Check -->
    <div class="col-12">
        <div class="section-card">
            <div class="d-flex align-items-center justify-content-between mb-3 flex-wrap gap-2">
                <h2 class="section-title mb-0"><i class="bi bi-heart-pulse me-2" style="color:var(--primary)"></i>System Health</h2>
                <button class="btn btn-primary btn-sm" @onclick="RunHealthCheck" disabled="@_healthRunning">
                    @if (_healthRunning)
                    {
                        <span class="spinner-border spinner-border-sm me-1" role="status" aria-hidden="true"></span>
                        <span>Checking…</span>
                    }
                    else
                    {
                        <i class="bi bi-play-circle me-1"></i><span>Run Health Check</span>
                    }
                </button>
            </div>
            @if (_healthChecks is not null)
            {
                <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(180px,1fr));gap:12px">
                    @foreach (var check in _healthChecks)
                    {
                        <div class="kpi-card" style="border-left:4px solid @(check.Ok ? "#28a745" : "#dc3545");text-align:left;min-height:90px">
                            <div style="font-size:1rem;margin-bottom:4px">
                                @if (check.Ok)
                                {
                                    <i class="bi bi-check-circle-fill" style="color:#28a745"></i>
                                }
                                else
                                {
                                    <i class="bi bi-x-circle-fill" style="color:#dc3545"></i>
                                }
                                <strong style="margin-left:6px;font-size:13px">@check.Name</strong>
                            </div>
                            <div style="font-size:11px;color:var(--text-muted)">@check.Detail</div>
                            @if (check.Ms >= 0)
                            {
                                <div style="font-size:11px;color:var(--text-muted)">@check.Ms ms</div>
                            }
                        </div>
                    }
                </div>
            }
            else
            {
                <p class="text-muted mb-0">Click <strong>Run Health Check</strong> to verify database connectivity and key API endpoints.</p>
            }
        </div>
    </div>

    <!-- REST API Reference -->
    <div class="col-md-8">
        <div class="section-card">
            <h2 class="section-title"><i class="bi bi-code-slash me-2" style="color:var(--primary)"></i>REST API Reference</h2>
            <p class="text-muted" style="font-size:13px">All endpoints are under <code>/api/</code> and accept an <code>X-Api-Key</code> header for machine access.</p>
            <div class="d-flex gap-2 mb-3">
                <a href="/scalar/v1" target="_blank" class="btn btn-primary btn-sm"><i class="bi bi-box-arrow-up-right me-1"></i>Interactive API Explorer</a>
                <a href="/openapi/v1.json" download="mate-openapi.json" class="btn btn-secondary btn-sm"><i class="bi bi-download me-1"></i>Download OpenAPI spec</a>
            </div>
            <table class="data-table" style="font-size:12px">
                <thead>
                    <tr><th style="width:60px">Method</th><th>Path</th><th>Description</th></tr>
                </thead>
                <tbody>
                    <tr><td colspan="3" style="background:var(--surface-2,#f8f9fa);font-weight:600;font-size:11px;padding:4px 8px">AGENTS</td></tr>
                    <tr><td><span class="badge" style="background:#61affe;color:#fff">GET</span></td><td><code>/api/agents</code></td><td>List all agents</td></tr>
                    <tr><td><span class="badge" style="background:#61affe;color:#fff">GET</span></td><td><code>/api/agents/{id}</code></td><td>Get a single agent</td></tr>
                    <tr><td><span class="badge" style="background:#49cc90;color:#fff">POST</span></td><td><code>/api/agents</code></td><td>Create an agent</td></tr>
                    <tr><td><span class="badge" style="background:#fca130;color:#fff">PUT</span></td><td><code>/api/agents/{id}</code></td><td>Update an agent</td></tr>
                    <tr><td><span class="badge" style="background:#f93e3e;color:#fff">DEL</span></td><td><code>/api/agents/{id}</code></td><td>Delete an agent</td></tr>
                    <tr><td><span class="badge" style="background:#fca130;color:#fff">PUT</span></td><td><code>/api/agents/{agentId}/connectors/{connectorId}</code></td><td>Update connector config</td></tr>
                    <tr><td colspan="3" style="background:var(--surface-2,#f8f9fa);font-weight:600;font-size:11px;padding:4px 8px">TEST SUITES &amp; CASES</td></tr>
                    <tr><td><span class="badge" style="background:#61affe;color:#fff">GET</span></td><td><code>/api/testsuites</code></td><td>List all test suites</td></tr>
                    <tr><td><span class="badge" style="background:#61affe;color:#fff">GET</span></td><td><code>/api/testsuites/{id}</code></td><td>Get a single test suite</td></tr>
                    <tr><td><span class="badge" style="background:#49cc90;color:#fff">POST</span></td><td><code>/api/testsuites</code></td><td>Create a test suite</td></tr>
                    <tr><td><span class="badge" style="background:#fca130;color:#fff">PUT</span></td><td><code>/api/testsuites/{id}</code></td><td>Update a test suite</td></tr>
                    <tr><td><span class="badge" style="background:#f93e3e;color:#fff">DEL</span></td><td><code>/api/testsuites/{id}</code></td><td>Delete a test suite</td></tr>
                    <tr><td><span class="badge" style="background:#61affe;color:#fff">GET</span></td><td><code>/api/testsuites/{id}/testcases</code></td><td>List test cases</td></tr>
                    <tr><td><span class="badge" style="background:#49cc90;color:#fff">POST</span></td><td><code>/api/testsuites/{id}/testcases</code></td><td>Create a test case</td></tr>
                    <tr><td><span class="badge" style="background:#fca130;color:#fff">PUT</span></td><td><code>/api/testcases/{id}</code></td><td>Update a test case</td></tr>
                    <tr><td><span class="badge" style="background:#f93e3e;color:#fff">DEL</span></td><td><code>/api/testcases/{id}</code></td><td>Delete a test case</td></tr>
                    <tr><td colspan="3" style="background:var(--surface-2,#f8f9fa);font-weight:600;font-size:11px;padding:4px 8px">RUNS &amp; RESULTS</td></tr>
                    <tr><td><span class="badge" style="background:#61affe;color:#fff">GET</span></td><td><code>/api/runs</code></td><td>List all runs</td></tr>
                    <tr><td><span class="badge" style="background:#61affe;color:#fff">GET</span></td><td><code>/api/runs/{id}</code></td><td>Get a single run</td></tr>
                    <tr><td><span class="badge" style="background:#49cc90;color:#fff">POST</span></td><td><code>/api/runs</code></td><td>Start a test run</td></tr>
                    <tr><td><span class="badge" style="background:#f93e3e;color:#fff">DEL</span></td><td><code>/api/runs/{id}</code></td><td>Delete a run</td></tr>
                    <tr><td><span class="badge" style="background:#61affe;color:#fff">GET</span></td><td><code>/api/runs/{id}/results</code></td><td>Get results for a run</td></tr>
                    <tr><td><span class="badge" style="background:#61affe;color:#fff">GET</span></td><td><code>/api/results/{id}/transcript</code></td><td>Get result transcript</td></tr>
                    <tr><td><span class="badge" style="background:#49cc90;color:#fff">POST</span></td><td><code>/api/results/{id}/human-verdict</code></td><td>Set human verdict</td></tr>
                    <tr><td colspan="3" style="background:var(--surface-2,#f8f9fa);font-weight:600;font-size:11px;padding:4px 8px">DOCUMENTS, METRICS &amp; SETTINGS</td></tr>
                    <tr><td><span class="badge" style="background:#61affe;color:#fff">GET</span></td><td><code>/api/documents</code></td><td>List documents</td></tr>
                    <tr><td><span class="badge" style="background:#49cc90;color:#fff">POST</span></td><td><code>/api/documents</code></td><td>Upload a document (multipart)</td></tr>
                    <tr><td><span class="badge" style="background:#f93e3e;color:#fff">DEL</span></td><td><code>/api/documents/{id}</code></td><td>Delete a document</td></tr>
                    <tr><td><span class="badge" style="background:#61affe;color:#fff">GET</span></td><td><code>/api/metrics/summary</code></td><td>Platform summary metrics</td></tr>
                    <tr><td><span class="badge" style="background:#61affe;color:#fff">GET</span></td><td><code>/api/judgesettings</code></td><td>List judge settings</td></tr>
                    <tr><td><span class="badge" style="background:#49cc90;color:#fff">POST</span></td><td><code>/api/judgesettings</code></td><td>Create a judge setting</td></tr>
                    <tr><td><span class="badge" style="background:#61affe;color:#fff">GET</span></td><td><code>/health</code></td><td>Health check (anonymous)</td></tr>
                </tbody>
            </table>
        </div>
    </div>

</div>
</div>

@code {
    private record HealthCheck(string Name, bool Ok, string Detail, long Ms);
    private bool _healthRunning;
    private List<HealthCheck>? _healthChecks;

    private string _appVersion     = "";
    private bool   _inContainer;
    private bool   _authEnabled;
    private string _authScheme     = "";
    private bool   _forwardedHeaders;

    protected override void OnInitialized()
    {
        var versionFile = Path.Combine(AppContext.BaseDirectory, "VERSION");
        if (File.Exists(versionFile))
            _appVersion = File.ReadAllText(versionFile).Trim();

        _inContainer = string.Equals(
            Environment.GetEnvironmentVariable("DOTNET_RUNNING_IN_CONTAINER"), "true",
            StringComparison.OrdinalIgnoreCase) || File.Exists("/.dockerenv");

        _authScheme  = Configuration["Authentication:Scheme"] ?? "None";
        _authEnabled = string.Equals(_authScheme, "EntraId", StringComparison.OrdinalIgnoreCase);

        _forwardedHeaders = string.Equals(
            Environment.GetEnvironmentVariable("ASPNETCORE_FORWARDEDHEADERS_ENABLED"), "true",
            StringComparison.OrdinalIgnoreCase);
    }

    private async Task RunHealthCheck()
    {
        _healthRunning = true;
        _healthChecks  = null;
        StateHasChanged();

        var results = new List<HealthCheck>();
        var sw      = Stopwatch.StartNew();

        // Database connectivity
        try
        {
            sw.Restart();
            var count = await Db.TestSuites.CountAsync();
            results.Add(new("Database", true, $"Reachable — {count} suite(s)", sw.ElapsedMilliseconds));
        }
        catch (Exception ex)
        {
            results.Add(new("Database", false, ex.Message[..Math.Min(60, ex.Message.Length)], -1));
        }

        // Agent count
        try
        {
            sw.Restart();
            var count = await Db.Agents.CountAsync();
            results.Add(new("Agents", true, $"{count} agent(s)", sw.ElapsedMilliseconds));
        }
        catch (Exception ex)
        {
            results.Add(new("Agents", false, ex.Message[..Math.Min(60, ex.Message.Length)], -1));
        }

        // Runs count
        try
        {
            sw.Restart();
            var count = await Db.Runs.CountAsync();
            results.Add(new("Runs", true, $"{count} run(s)", sw.ElapsedMilliseconds));
        }
        catch (Exception ex)
        {
            results.Add(new("Runs", false, ex.Message[..Math.Min(60, ex.Message.Length)], -1));
        }

        // Documents count
        try
        {
            sw.Restart();
            var count = await Db.Documents.CountAsync();
            results.Add(new("Documents", true, $"{count} document(s)", sw.ElapsedMilliseconds));
        }
        catch (Exception ex)
        {
            results.Add(new("Documents", false, ex.Message[..Math.Min(60, ex.Message.Length)], -1));
        }

        // HTTP self-check: /health endpoint
        try
        {
            var baseUri = NavigationManager.BaseUri.TrimEnd('/');
            var client  = HttpClientFactory.CreateClient();
            using var cts = new System.Threading.CancellationTokenSource(TimeSpan.FromSeconds(5));
            sw.Restart();
            var resp = await client.GetAsync(baseUri + "/health", cts.Token);
            var ok   = (int)resp.StatusCode < 500;
            results.Add(new("/health endpoint", ok, $"HTTP {(int)resp.StatusCode}", sw.ElapsedMilliseconds));
        }
        catch (Exception ex)
        {
            results.Add(new("/health endpoint", false, ex.Message[..Math.Min(60, ex.Message.Length)], -1));
        }

        _healthChecks = results;
        _healthRunning = false;
    }
}
