@inherits LayoutComponentBase
@inject NavigationManager Navigation
@inject IJSRuntime JS
@inject IConfiguration Configuration
@using System.Security.Claims
@implements IDisposable

<!-- Sidebar -->
<div class="mate-sidebar @(_expanded ? "expanded" : "collapsed") @(_isMobile ? "mobile" : "")">

    <!-- Toggle -->
    <div class="sidebar-toggle">
        <button class="sidebar-toggle-btn" @onclick="ToggleSidebar" title="Toggle menu">
            <i class="bi @(_expanded ? "bi-chevron-left" : "bi-chevron-right")"></i>
        </button>
    </div>

    <!-- Brand -->
    <div class="sidebar-brand" @onclick='() => Navigation.NavigateTo("/")'>
        <img src="@BrandInfo.LogoUrl" alt="@BrandInfo.BrandName logo" class="sidebar-brand-logo" />
        @if (_expanded)
        {
            <span class="sidebar-brand-text">@BrandInfo.BrandName</span>
        }
    </div>

    <!-- Primary nav -->
    <nav class="sidebar-nav">
        <NavItem Href="/"            Icon="bi-house-door"        Label="Home"        Expanded="@_expanded" CurrentPage="@_currentPage" PageKey="home" />
        <NavItem Href="/wizard"      Icon="bi-magic"             Label="Wizard"      Expanded="@_expanded" CurrentPage="@_currentPage" PageKey="wizard" />
        <NavItem Href="/test-suites" Icon="bi-list-check"        Label="Test Suites" Expanded="@_expanded" CurrentPage="@_currentPage" PageKey="test-suites" />
        <NavItem Href="/documents"   Icon="bi-file-earmark-text" Label="Documents"   Expanded="@_expanded" CurrentPage="@_currentPage" PageKey="documents" />
        <NavItem Href="/agents"      Icon="bi-robot"             Label="Agents"      Expanded="@_expanded" CurrentPage="@_currentPage" PageKey="agents" />
        <NavItem Href="/dashboard"   Icon="bi-graph-up"          Label="Dashboard"   Expanded="@_expanded" CurrentPage="@_currentPage" PageKey="dashboard" />
        <NavItem Href="/rubrics"     Icon="bi-award"             Label="Rubrics"     Expanded="@_expanded" CurrentPage="@_currentPage" PageKey="rubrics" />
    </nav>

    <!-- Bottom nav (admin) -->
    <div class="sidebar-bottom">
        <NavItem Href="/help"      Icon="bi-question-circle" Label="Help"      Expanded="@_expanded" CurrentPage="@_currentPage" PageKey="help" />
        <NavItem Href="/audit-log" Icon="bi-journal-check"   Label="Audit Log" Expanded="@_expanded" CurrentPage="@_currentPage" PageKey="audit-log" />
        <NavItem Href="/api-keys"  Icon="bi-key"             Label="API Keys"  Expanded="@_expanded" CurrentPage="@_currentPage" PageKey="api-keys" />
        <NavItem Href="/settings"  Icon="bi-gear"            Label="Settings"  Expanded="@_expanded" CurrentPage="@_currentPage" PageKey="settings" />

        <!-- Dark mode toggle -->
        <button class="sidebar-darkmode-btn" @onclick="ToggleDarkMode" title="Toggle dark mode">
            <i class="bi @(_darkMode ? "bi-sun" : "bi-moon-stars")"></i>
            @if (_expanded) { <span>@(_darkMode ? "Light mode" : "Dark mode")</span> }
        </button>
    </div>
</div>

<!-- Main content -->
<div class="mate-main @(_expanded ? "expanded" : "collapsed")">

    <!-- Top bar -->
    <div class="mate-topbar">
        @if (_isMobile)
        {
            <button class="topbar-menu-btn" @onclick="ToggleSidebar" title="Toggle menu" aria-label="Toggle menu">
                <i class="bi-list"></i>
            </button>
        }

        <div class="mate-topbar-user">
            <AuthorizeView>
                <Authorized Context="authCtx">
                    <button class="topbar-user-btn" @onclick="ToggleUserPopup"
                            title="@(authCtx.User.Identity?.Name ?? "User")">
                        <span class="topbar-user-name d-none d-md-inline">@(authCtx.User.Identity?.Name ?? "User")</span>
                        <div class="user-avatar @(IsDevScheme() ? "user-avatar-dev" : "")">
                            @GetInitials(authCtx.User.Identity?.Name ?? "User")
                        </div>
                    </button>
                    @if (_userPopupOpen)
                    {
                        <div class="user-popup user-popup-top">
                            <div class="d-flex align-items-center gap-3 mb-2">
                                <div class="user-avatar user-avatar-lg @(IsDevScheme() ? "user-avatar-dev" : "")">
                                    @GetInitials(authCtx.User.Identity?.Name ?? "User")
                                </div>
                                <div style="overflow:hidden;min-width:0">
                                    <p class="user-popup-name">@(authCtx.User.Identity?.Name ?? "User")</p>
                                    @{ var email = authCtx.User.FindFirst(ClaimTypes.Email)?.Value; }
                                    @if (!string.IsNullOrEmpty(email)) { <p class="user-popup-email">@email</p> }
                                </div>
                            </div>
                            @{ var roleDisplay = GetUserRoleDisplay(authCtx.User); }
                            @if (!string.IsNullOrEmpty(roleDisplay.PrimaryRole))
                            {
                                <span class="user-popup-role-badge @(IsDevScheme() ? "dev" : "")">@roleDisplay.PrimaryRole</span>
                                @if (roleDisplay.AllRoles.Count > 1)
                                {
                                    <p class="user-popup-email mt-1 mb-0">Roles: @string.Join(", ", roleDisplay.AllRoles)</p>
                                }
                            }
                            <span class="user-popup-scheme-badge">@_authScheme</span>
                            <hr class="user-popup-divider" />
                            @if (IsEntraScheme())
                            {
                                <a href="/MicrosoftIdentity/Account/SignOut" class="user-popup-logout" @onclick="SignOut" @onclick:preventDefault="true">
                                    <i class="bi bi-box-arrow-right me-1"></i>Sign out
                                </a>
                            }
                            else
                            {
                                <div class="user-popup-devnote">
                                    <i class="bi bi-info-circle me-1"></i>Development mode — all requests are authenticated as SuperAdmin.
                                </div>
                            }
                        </div>
                    }
                </Authorized>
                <NotAuthorized>
                    <div class="topbar-user-btn" title="Not authenticated">
                        <div class="user-avatar user-avatar-none">?</div>
                    </div>
                </NotAuthorized>
            </AuthorizeView>
        </div>
    </div>

    <!-- Page body -->
    <div class="mate-page">
        @Body
    </div>
</div>

<!-- Close popup overlay -->
@if (_userPopupOpen)
{
    <div class="sidebar-backdrop" @onclick="CloseUserPopup"></div>
}

@if (_isMobile && _expanded)
{
    <div class="sidebar-menu-backdrop" @onclick="ToggleSidebar"></div>
}

@code {
    private bool _expanded = true;
    private string _currentPage = "home";
    private bool _darkMode;
    private bool _layoutFirstRender;
    private bool _userPopupOpen;
    private string _authScheme = "None";
    private bool _isMobile;

    protected override void OnInitialized()
    {
        Navigation.LocationChanged += OnLocationChanged;
        UpdateCurrentPage(Navigation.Uri);
        _authScheme = Configuration["Authentication:Scheme"] ?? "None";
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender && !_layoutFirstRender)
        {
            _layoutFirstRender = true;
            try
            {
                _darkMode = await JS.InvokeAsync<bool>("mateInitDarkMode");
                _isMobile = await JS.InvokeAsync<bool>("mateIsMobile");
                if (_isMobile)
                {
                    _expanded = false;
                }
            }
            catch (Exception)
            {
                // JS not ready yet — dark mode defaults to light
            }
            StateHasChanged();
        }
    }

    private async Task ToggleDarkMode()
    {
        _darkMode = !_darkMode;
        await JS.InvokeVoidAsync("mateSetDarkMode", _darkMode);
    }

    private void ToggleUserPopup() => _userPopupOpen = !_userPopupOpen;
    private void CloseUserPopup()  => _userPopupOpen = false;

    private void SignOut()
    {
        _userPopupOpen = false;
        Navigation.NavigateTo("/MicrosoftIdentity/Account/SignOut", forceLoad: true);
    }

    private bool IsEntraScheme() => string.Equals(_authScheme, "EntraId", StringComparison.OrdinalIgnoreCase);
    private bool IsDevScheme()   => string.Equals(_authScheme, "Generic", StringComparison.OrdinalIgnoreCase)
                                 || string.Equals(_authScheme, "None",    StringComparison.OrdinalIgnoreCase);

    private static string GetInitials(string name)
    {
        if (string.IsNullOrWhiteSpace(name)) return "?";
        var parts = name.Trim().Split(' ', StringSplitOptions.RemoveEmptyEntries);
        return parts.Length == 1
            ? parts[0][0].ToString().ToUpper()
            : (parts[0][0].ToString() + parts[^1][0].ToString()).ToUpper();
    }

    private sealed record RoleDisplay(string PrimaryRole, IReadOnlyList<string> AllRoles);

    private static string? NormalizeRole(string? role)
    {
        if (string.IsNullOrWhiteSpace(role)) return null;

        return role.Trim().ToLowerInvariant() switch
        {
            "superadmin" => "SuperAdmin",
            "platformadmin" => "SuperAdmin",
            "tenantadmin" => "TenantAdmin",
            "tenatadmin" => "TenantAdmin",
            "tester" => "Tester",
            "viewer" => "Viewer",
            _ => role.Trim(),
        };
    }

    private static RoleDisplay GetUserRoleDisplay(ClaimsPrincipal user)
    {
        var orderedKnownRoles = new[] { "SuperAdmin", "TenantAdmin", "Tester", "Viewer" };
        var roleSet = new HashSet<string>(StringComparer.Ordinal);

        foreach (var claim in user.FindAll(ClaimTypes.Role))
        {
            var normalized = NormalizeRole(claim.Value);
            if (!string.IsNullOrWhiteSpace(normalized))
                roleSet.Add(normalized);
        }

        foreach (var claim in user.FindAll("roles"))
        {
            var normalized = NormalizeRole(claim.Value);
            if (!string.IsNullOrWhiteSpace(normalized))
                roleSet.Add(normalized);
        }

        foreach (var claim in user.FindAll("mate:role"))
        {
            var normalized = NormalizeRole(claim.Value);
            if (!string.IsNullOrWhiteSpace(normalized))
                roleSet.Add(normalized);
        }

        // Viewer is implicit when higher privileges are present; suppress it in the role badge list.
        if (roleSet.Contains("SuperAdmin") || roleSet.Contains("TenantAdmin") || roleSet.Contains("Tester"))
            roleSet.Remove("Viewer");

        var result = orderedKnownRoles.Where(roleSet.Contains).ToList();
        var unknown = roleSet.Where(r => !orderedKnownRoles.Contains(r, StringComparer.Ordinal))
            .OrderBy(r => r, StringComparer.Ordinal)
            .ToList();
        result.AddRange(unknown);

        if (result.Count == 0)
            return new RoleDisplay("", Array.Empty<string>());

        return new RoleDisplay(result[0], result);
    }

    private void OnLocationChanged(object? sender, Microsoft.AspNetCore.Components.Routing.LocationChangedEventArgs e)
        => InvokeAsync(() =>
        {
            UpdateCurrentPage(e.Location);
            _userPopupOpen = false;
            if (_isMobile)
            {
                _expanded = false;
            }
            StateHasChanged();
        });

    private void UpdateCurrentPage(string uri)
    {
        var path = new Uri(uri).AbsolutePath.TrimStart('/').ToLowerInvariant();
        _currentPage = path switch
        {
            "" or "home" => "home",
            var p when p.StartsWith("wizard")     => "wizard",
            var p when p.StartsWith("test-suite") => "test-suites",
            var p when p.StartsWith("document")   => "documents",
            var p when p.StartsWith("agent")      => "agents",
            var p when p.StartsWith("discover")   => "discover",
            var p when p.StartsWith("dashboard")  => "dashboard",
            var p when p.StartsWith("rubric")     => "rubrics",
            var p when p.StartsWith("help")       => "help",
            var p when p.StartsWith("audit-log")  => "audit-log",
            var p when p.StartsWith("api-key")    => "api-keys",
            var p when p.StartsWith("setting")    => "settings",
            _ => "home"
        };
    }

    private void ToggleSidebar() => _expanded = !_expanded;

    public void Dispose() => Navigation.LocationChanged -= OnLocationChanged;
}
