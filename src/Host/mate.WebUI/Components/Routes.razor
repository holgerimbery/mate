@using Microsoft.AspNetCore.Components.Routing
@using System.Reflection

@code {
    // Explicitly load enterprise RCL when present so route discovery works in enterprise builds.
    private static readonly IReadOnlyList<Assembly> _additionalAssemblies = ResolveAdditionalAssemblies();

    private static IReadOnlyList<Assembly> ResolveAdditionalAssemblies()
    {
        try
        {
            return [Assembly.Load("mate.Enterprise.WebUI")];
        }
        catch
        {
            return [];
        }
    }
}

<Router AppAssembly="@typeof(App).Assembly" AdditionalAssemblies="@_additionalAssemblies">
    <Found Context="routeData">
        <RouteView RouteData="@routeData" DefaultLayout="@typeof(MainLayout)" />
        <FocusOnNavigate RouteData="@routeData" Selector="h1" />
    </Found>
    <NotFound>
        <PageTitle>Not found</PageTitle>
        <LayoutView Layout="@typeof(MainLayout)">
            <p role="alert">Sorry, there's nothing at this address.</p>
        </LayoutView>
    </NotFound>
</Router>
