# ── Authentication ────────────────────────────────────────────────────────────
#
# Authentication__Scheme=Generic  →  no login required; all users get Admin access.
#   Use this only on a trusted internal network or behind a VPN.
#   NEVER use Generic if the app is reachable from the internet.
#
# Authentication__Scheme=EntraId  →  Microsoft Entra ID (Azure AD) SSO with RBAC.
#   Requires the AzureAd__* values below.
#   See: https://github.com/holgerimbery/mate/wiki/User-API-Keys
#
Authentication__Scheme=Generic

# ── Entra ID (required only when Authentication__Scheme=EntraId) ───────────
AzureAd__Instance=https://login.microsoftonline.com/
AzureAd__TenantId=
AzureAd__ClientId=
AzureAd__ClientSecret=
# Public URL that your reverse proxy exposes — used to build the OIDC redirect_uri.
# Example: https://mate.example.com
AzureAd__RedirectUri=
# Callback paths — must match Redirect URIs registered in Entra ID (defaults are correct)
AzureAd__CallbackPath=/signin-oidc
AzureAd__SignedOutCallbackPath=/signout-callback-oidc

# ── Reverse proxy ─────────────────────────────────────────────────────────────
# IP address of your nginx / Caddy / Traefik proxy.
# Leave empty to trust the entire Docker bridge network (172.16/12).
ReverseProxy__TrustedProxyAddress=

# ── Image version (optional) ──────────────────────────────────────────────────
# Pin to a specific release tag to avoid unintended upgrades.
# Leave empty (or omit) to always pull :latest.
# Example: IMAGE_TAG=0.6.0
IMAGE_TAG=

